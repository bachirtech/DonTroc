{
  "rules": {
    ".read": false,
    ".write": false,
    
    "Annonces": {
      ".indexOn": ["UtilisateurId", "Categorie", "Type", "DateCreationTimestamp", "IsFlagged"],
      ".read": "auth != null",
      "$annonceId": {
        ".write": "auth != null && (!data.exists() && newData.child('UtilisateurId').val() == auth.uid || data.child('UtilisateurId').val() == auth.uid || root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1)",
        ".validate": "newData.hasChildren(['UtilisateurId', 'Titre', 'Description', 'Categorie', 'Type', 'DateCreationTimestamp']) && newData.child('Titre').isString() && newData.child('Titre').val().length > 0 && newData.child('Titre').val().length <= 100 && newData.child('Description').isString() && newData.child('Description').val().length <= 2000",
        "IsFlagged": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1"
        },
        "FlagReason": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1"
        },
        "FlaggedAt": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1"
        }
      }
    },

    "UserProfiles": {
      ".indexOn": ["Role", "DateInscription", "IsSuspended", "GeoHash", "LastActiveAt"],
      ".read": "auth != null",
      "$userId": {
        ".write": "auth != null && (auth.uid == $userId || root.child('UserProfiles/' + auth.uid + '/Role').val() == 2)",
        ".validate": "newData.hasChildren(['Id', 'Name']) && newData.child('Name').isString() && newData.child('Name').val().length <= 50",
        "LastLatitude": { ".validate": "newData.isNumber()" },
        "LastLongitude": { ".validate": "newData.isNumber()" },
        "LastLocationUpdate": { ".validate": "newData.isString()" },
        "GeoHash": { ".validate": "newData.isString() && newData.val().length <= 12" },
        "ProximityNotificationsEnabled": { ".validate": "newData.isBoolean()" },
        "NotificationRadius": { ".validate": "newData.isNumber()" },
        "LastActiveAt": { ".validate": "newData.isNumber()" },
        "NotificationPreferences": {
          "$prefKey": {
            ".validate": "newData.isBoolean()"
          }
        },
        "Role": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() == 2"
        },
        "IsSuspended": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1"
        },
        "SuspensionReason": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1"
        },
        "SuspensionDate": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1"
        },
        "SuspensionEndDate": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1"
        },
        "SuspendedBy": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1"
        },
        "IsDeleted": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() == 2"
        },
        "DeletedAt": {
          ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() == 2"
        }
      }
    },
    
    "UserStats": {
      "$userId": {
        ".read": "auth != null",
        ".write": "auth.uid == $userId",
        ".validate": "newData.child('UserId').val() == auth.uid"
      }
    },
    
    "Conversations": {
      ".indexOn": ["BuyerId", "SellerId", "LastMessageTimestamp", "AnnonceId"],
      "$conversationId": {
        ".read": "auth != null && (data.child('ParticipantIds').child(auth.uid).val() === true || data.child('BuyerId').val() == auth.uid || data.child('SellerId').val() == auth.uid)",
        ".write": "auth != null && (!data.exists() || data.child('ParticipantIds').child(auth.uid).val() === true || data.child('BuyerId').val() == auth.uid || data.child('SellerId').val() == auth.uid)",
        ".validate": "newData.hasChildren(['AnnonceId', 'LastMessageTimestamp']) && (newData.child('ParticipantIds').hasChild(auth.uid) || newData.child('BuyerId').val() == auth.uid || newData.child('SellerId').val() == auth.uid)"
      }
    },

    "Messages": {
      ".indexOn": ["SenderId", "Timestamp"],
      "$conversationId": {
        ".indexOn": ["Timestamp"],
        ".read": "auth != null && (root.child('Conversations/' + $conversationId + '/ParticipantIds/' + auth.uid).val() === true || root.child('Conversations/' + $conversationId + '/BuyerId').val() == auth.uid || root.child('Conversations/' + $conversationId + '/SellerId').val() == auth.uid)",
        ".write": "auth != null && (root.child('Conversations/' + $conversationId + '/ParticipantIds/' + auth.uid).val() === true || root.child('Conversations/' + $conversationId + '/BuyerId').val() == auth.uid || root.child('Conversations/' + $conversationId + '/SellerId').val() == auth.uid)",
        "$messageId": {
          ".validate": "(newData.hasChildren(['SenderId', 'Timestamp']) && newData.child('SenderId').val() == auth.uid) || (data.exists() && (newData.child('IsRead').exists() || newData.child('Status').exists() || newData.child('ReadAt').exists()))"
        }
      }
    },
    
    "transactions": {
      ".indexOn": ["ProprietaireId", "DemandeurId", "DateCreation", "Statut"],
      "$transactionId": {
        ".read": "auth != null && (data.child('ProprietaireId').val() == auth.uid || data.child('DemandeurId').val() == auth.uid)",
        ".write": "auth != null && (!data.exists() || data.child('ProprietaireId').val() == auth.uid || data.child('DemandeurId').val() == auth.uid)",
        ".validate": "newData.hasChildren(['AnnonceId', 'ProprietaireId', 'DemandeurId'])"
      }
    },

    "tradeProposals": {
      ".indexOn": ["OwnerId", "ProposerId", "AnnonceCibleId", "OfferedAnnonceId", "Statut", "DateCreationTimestamp"],
      "$proposalId": {
        ".read": "auth != null && (data.child('OwnerId').val() == auth.uid || data.child('ProposerId').val() == auth.uid)",
        ".write": "auth != null && ((!data.exists() && newData.child('ProposerId').val() == auth.uid) || data.child('OwnerId').val() == auth.uid || data.child('ProposerId').val() == auth.uid)",
        ".validate": "newData.hasChildren(['AnnonceCibleId', 'OfferedAnnonceId', 'ProposerId', 'OwnerId', 'DateCreationTimestamp']) && newData.child('ProposerId').val() != newData.child('OwnerId').val()"
      }
    },
    
    "favorites": {
      ".indexOn": ["UserId", "AnnonceId"],
      "$favoriteId": {
        ".read": "auth != null && data.child('UserId').val() == auth.uid",
        ".write": "auth != null && (data.child('UserId').val() == auth.uid || (!data.exists() && newData.child('UserId').val() == auth.uid))",
        ".validate": "newData.hasChildren(['UserId', 'AnnonceId']) && newData.child('UserId').val() == auth.uid"
      }
    },
    
    "favoriteLists": {
      ".indexOn": ["UserId"],
      "$listId": {
        ".read": "auth != null && data.child('UserId').val() == auth.uid",
        ".write": "auth != null && (data.child('UserId').val() == auth.uid || (!data.exists() && newData.child('UserId').val() == auth.uid))",
        ".validate": "newData.hasChildren(['UserId', 'Name']) && newData.child('UserId').val() == auth.uid && newData.child('Name').isString() && newData.child('Name').val().length <= 50"
      }
    },
    
    "annonceAlerts": {
      ".indexOn": ["UserId"],
      "$alertId": {
        ".read": "auth != null && data.child('UserId').val() == auth.uid",
        ".write": "auth != null && (data.child('UserId').val() == auth.uid || (!data.exists() && newData.child('UserId').val() == auth.uid))",
        ".validate": "newData.hasChildren(['UserId', 'Name']) && newData.child('UserId').val() == auth.uid"
      }
    },
    
    "Notifications": {
      "$userId": {
        ".read": "auth.uid == $userId",
        ".write": "auth.uid == $userId",
        "$notificationId": {
          ".validate": "newData.hasChildren(['Timestamp']) && newData.child('UserId').val() == auth.uid"
        }
      }
    },
    
    "Ratings": {
      ".indexOn": ["EvalueId", "EvaluateurId", "TransactionId", "DateCreation"],
      ".read": "auth != null",
      "$ratingId": {
        ".write": "auth != null && newData.child('EvaluateurId').val() == auth.uid",
        ".validate": "newData.hasChildren(['EvalueId', 'EvaluateurId', 'Note', 'TransactionId', 'DateCreation']) && newData.child('EvaluateurId').val() == auth.uid && newData.child('Note').isNumber() && newData.child('Note').val() >= 1 && newData.child('Note').val() <= 5"
      }
    },
    
    "reports": {
      ".indexOn": ["ReporterId", "Status", "Timestamp", "TargetType"],
      ".read": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1",
      "$reportId": {
        ".write": "auth != null && (!data.exists() && newData.child('ReporterId').val() == auth.uid || root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1)",
        ".validate": "newData.hasChildren(['ReporterId', 'Reason', 'Timestamp']) && newData.child('Reason').isString() && newData.child('Reason').val().length <= 1000"
      }
    },
    
    "admins": {
      ".read": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1",
      ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() == 2"
    },
    
    "admin_logs": {
      ".indexOn": ["AdminId", "ActionType", "Timestamp"],
      ".read": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1",
      "$logId": {
        ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1",
        ".validate": "newData.hasChildren(['AdminId', 'ActionType', 'Timestamp'])"
      }
    },
    
    "UserActions": {
      "$userId": {
        ".indexOn": ["ActionType", "Timestamp"],
        ".read": "auth != null && auth.uid == $userId",
        ".write": "auth != null && auth.uid == $userId",
        "$actionId": {
          ".validate": "newData.hasChildren(['UserId', 'ActionType', 'Timestamp']) && newData.child('UserId').val() == auth.uid"
        }
      }
    },
    
    "ProximityNotificationStats": {
      ".indexOn": ["AnnonceId", "Timestamp"],
      ".read": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() >= 1",
      "$annonceId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['AnnonceId', 'NotificationsSent', 'Timestamp'])"
      }
    },
    
    "TypingIndicators": {
      "$conversationId": {
        ".read": "auth != null && (root.child('Conversations/' + $conversationId + '/ParticipantIds/' + auth.uid).val() === true || root.child('Conversations/' + $conversationId + '/BuyerId').val() == auth.uid || root.child('Conversations/' + $conversationId + '/SellerId').val() == auth.uid)",
        ".write": "auth != null && (root.child('Conversations/' + $conversationId + '/ParticipantIds/' + auth.uid).val() === true || root.child('Conversations/' + $conversationId + '/BuyerId').val() == auth.uid || root.child('Conversations/' + $conversationId + '/SellerId').val() == auth.uid)",
        "$userId": {
          ".validate": "newData.isNumber() && $userId == auth.uid"
        }
      }
    },
    
    "referral_codes": {
      ".indexOn": ["UserId", "Code"],
      ".read": "auth != null",
      "$codeId": {
        ".write": "auth != null && (!data.exists() && newData.child('UserId').val() == auth.uid || data.exists())",
        ".validate": "newData.hasChildren(['UserId', 'Code', 'DateCreation']) && newData.child('Code').isString() && (!data.exists() || (newData.child('UserId').val() == data.child('UserId').val() && newData.child('Code').val() == data.child('Code').val()))"
      }
    },
    
    "friendships": {
      ".indexOn": ["UserId", "FriendId", "Status"],
      ".read": "auth != null",
      "$friendshipId": {
        ".write": "auth != null && (!data.exists() || data.child('UserId').val() == auth.uid || data.child('FriendId').val() == auth.uid)",
        ".validate": "newData.hasChildren(['UserId', 'FriendId', 'Status', 'DateCreation'])"
      }
    },
    
    "social_shares": {
      ".indexOn": ["UserId", "AnnonceId", "DatePartage"],
      ".read": "auth != null",
      "$shareId": {
        ".write": "auth != null && newData.child('UserId').val() == auth.uid",
        ".validate": "newData.hasChildren(['UserId', 'AnnonceId', 'Platform', 'DatePartage']) && newData.child('UserId').val() == auth.uid"
      }
    },
    
    "friend_activities": {
      ".indexOn": ["UserId", "DateActivite"],
      ".read": "auth != null",
      "$activityId": {
        ".write": "auth != null && newData.child('UserId').val() == auth.uid",
        ".validate": "newData.hasChildren(['UserId', 'Type', 'DateActivite']) && newData.child('UserId').val() == auth.uid"
      }
    },
    
    "RemindersSent": {
      ".read": false,
      ".write": false,
      "$userId": {
        "$reminderType": {
          ".validate": "newData.isNumber()"
        }
      }
    },

    "app_config": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('UserProfiles/' + auth.uid + '/Role').val() == 2",
      "$platform": {
        ".validate": "$platform == 'android' || $platform == 'ios'"
      }
    }
  }
}

