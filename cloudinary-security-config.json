{
  "cloudinary_security_rules": {
    "upload_restrictions": {
      "max_file_size_mb": 10,
      "max_files_per_upload": 5,
      "max_files_per_user_per_day": 50,
      "allowed_formats": ["jpg", "jpeg", "png", "webp", "gif"],
      "min_file_size_bytes": 100,
      "max_image_dimensions": {
        "width": 4000,
        "height": 4000
      }
    },
    "security_transformations": {
      "auto_optimize": true,
      "strip_metadata": true,
      "quality": "auto:good",
      "fetch_format": "auto",
      "max_display_size": {
        "width": 1200,
        "height": 1200
      }
    },
    "folder_structure": {
      "user_uploads": "dontroc/users/{user_id}/",
      "profile_pictures": "dontroc/profiles/",
      "temporary": "dontroc/temp/",
      "archived": "dontroc/archived/"
    },
    "tagging_strategy": {
      "required_tags": ["dontroc", "user_upload"],
      "user_tag": "user_{user_id}",
      "date_tag": "upload_{YYYYMMDD}",
      "type_tags": ["annonce", "profile", "message"]
    },
    "rate_limiting": {
      "uploads_per_minute": 10,
      "uploads_per_hour": 100,
      "uploads_per_day": 500
    },
    "content_moderation": {
      "enable_ai_moderation": false,
      "block_inappropriate": true,
      "enable_virus_scan": true,
      "quarantine_suspicious": true
    }
  },
  "cloud_name": "your_cloudinary_cloud_name",
  "api_key": "your_cloudinary_api_key",
  "api_secret": "your_cloudinary_api_secret",
  "secure": true,
  "upload_preset": "dontroc_uploads",
  "folder": "dontroc",
  "transformation": {
    "quality": "auto:good",
    "fetch_format": "auto",
    "width": 800,
    "height": 600,
    "crop": "limit"
  },
  "security_options": {
    "allowed_formats": ["jpg", "jpeg", "png", "webp"],
    "max_file_size": 5242880,
    "resource_type": "image",
    "access_mode": "public"
  }
}
