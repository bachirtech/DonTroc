<?xml version="1.0" encoding="UTF-8"?>
<metadata>
  <!-- 
    Metadata.xml pour IronSource SDK 9.2.0
    Ce fichier résout les conflits entre les types Java et C#
  -->

  <!-- ═══════════════════════════════════════════════════════════════════
       EXCLUSIONS MASSIVES - Le SDK IronSource est fortement obfusqué
       On garde uniquement les classes publiques nécessaires
       ═══════════════════════════════════════════════════════════════════ -->
  
  <!-- Exclure TOUT le package com.ironsource (classes obfusquées) -->
  <remove-node path="/api/package[@name='com.ironsource']" />
  
  <!-- Exclure les adapters internes -->
  <remove-node path="/api/package[@name='com.ironsource.adapters']" />
  <remove-node path="/api/package[starts-with(@name, 'com.ironsource.adapters')]" />
  
  <!-- Exclure les packages SDK internes -->
  <remove-node path="/api/package[@name='com.ironsource.mediationsdk.server']" />
  <remove-node path="/api/package[@name='com.ironsource.mediationsdk.bidding']" />
  <remove-node path="/api/package[@name='com.ironsource.mediationsdk.integration']" />
  <remove-node path="/api/package[@name='com.ironsource.mediationsdk.adunit']" />
  <remove-node path="/api/package[starts-with(@name, 'com.ironsource.mediationsdk.adunit')]" />
  <remove-node path="/api/package[starts-with(@name, 'com.ironsource.mediationsdk.impressionData')]" />
  <remove-node path="/api/package[starts-with(@name, 'com.ironsource.mediationsdk.metadata')]" />
  
  <!-- Exclure les interfaces SmashListener qui ont des méthodes dupliquées -->
  <remove-node path="/api/package[@name='com.ironsource.mediationsdk.sdk']/interface[@name='BannerSmashListener']" />
  <remove-node path="/api/package[@name='com.ironsource.mediationsdk.sdk']/interface[@name='InterstitialSmashListener']" />
  <remove-node path="/api/package[@name='com.ironsource.mediationsdk.sdk']/interface[@name='RewardedVideoSmashListener']" />
  
  <!-- Exclure toutes les interfaces avec "Smash" dans le nom -->
  <remove-node path="//interface[contains(@name, 'Smash')]" />
  
  <!-- Exclure les classes R (ressources Android) et BuildConfig -->
  <remove-node path="//class[starts-with(@name, 'R$')]" />
  <remove-node path="//class[@name='R']" />
  <remove-node path="//class[@name='BuildConfig']" />
  
  <!-- Exclure les classes avec des noms d'une seule lettre (obfusquées) -->
  <remove-node path="//class[string-length(@name) = 1]" />
  <remove-node path="//interface[string-length(@name) = 1]" />
  
  <!-- Supprimer les méthodes Finalize -->
  <remove-node path="//method[@name='finalize']" />
  
  <!-- ═══════════════════════════════════════════════════════════════════
       RENOMMAGES - Pour éviter les conflits C#
       ═══════════════════════════════════════════════════════════════════ -->
  
  <!-- Renommer le package principal pour C# -->
  <attr path="/api/package[@name='com.ironsource.mediationsdk']" 
        name="managedName">IronSource.SDK</attr>
  
  <attr path="/api/package[@name='com.ironsource.mediationsdk.logger']" 
        name="managedName">IronSource.SDK.Logger</attr>
  
  <attr path="/api/package[@name='com.ironsource.mediationsdk.model']" 
        name="managedName">IronSource.SDK.Model</attr>
  
  <attr path="/api/package[@name='com.ironsource.mediationsdk.sdk']" 
        name="managedName">IronSource.SDK.Listeners</attr>
  
  <attr path="/api/package[@name='com.ironsource.mediationsdk.utils']" 
        name="managedName">IronSource.SDK.Utils</attr>

  <!-- Rendre les classes principales publiques -->
  <attr path="/api/package[@name='com.ironsource.mediationsdk']/class[@name='IronSource']" 
        name="visibility">public</attr>

</metadata>
