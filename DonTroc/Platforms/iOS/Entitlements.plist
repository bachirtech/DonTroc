<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Push Notifications (pour Firebase Cloud Messaging) -->
	<key>aps-environment</key>
	<string>development</string>
	
	<!-- Accès au trousseau pour stocker les credentials de façon sécurisée -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.bachirdev.dontroc</string>
	</array>
	
	<!-- Associated Domains (pour les liens universels si nécessaire) -->
	<!-- Décommenter si vous avez configuré les liens universels sur votre serveur
