	<string>6.0</string>
	<!-- 🍎 FIX icône iOS + logo notifications push :
	     Depuis iOS 11, Apple exige CFBundleIconName pour faire le lien
	     entre le bundle et l'asset catalog (Assets.car → appicon.appiconset).
	     Sans cette clé : icône grise par défaut sur le springboard ET
	     pas de logo DonTroc dans les notifications push (iOS utilise
	     automatiquement l'icône de l'app pour le badge des notifs).
	     La valeur "appicon" doit correspondre EXACTEMENT au nom du
	     `*.appiconset` généré par Resizetizer MAUI dans
	     obj/Debug/net9.0-ios/.../Assets.xcassets/appicon.appiconset/ -->
	<key>CFBundleIconName</key>
	<string>appicon</string>
	<!-- Compat Xamarin/legacy + outils CI : pointe vers le même asset. -->
	<key>XSAppIconAssets</key>
	<string>Assets.xcassets/appicon.appiconset</string>
