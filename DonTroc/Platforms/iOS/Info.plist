	<!-- === PERMISSIONS D'ACCÈS === -->
	
	<!-- Contacts - Pour partager des annonces/invitations avec vos proches -->
	<key>NSContactsUsageDescription</key>
	<string>DonTroc pourrait demander l'accès à vos contacts pour faciliter le partage d'annonces ou d'invitations avec vos proches. Aucune donnée de contact n'est collectée sans votre consentement explicite.</string>
	<!-- Caméra - Pour prendre des photos des objets à donner/échanger -->
	<key>NSCameraUsageDescription</key>
	<string>DonTroc utilise la caméra pour vous permettre de prendre des photos de vos objets à donner ou échanger.</string>
	
	<!-- Bibliothèque photos - Pour sélectionner des photos existantes -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>DonTroc accède à votre photothèque pour vous permettre de sélectionner des photos de vos objets.</string>
	
	<!-- Ajout de photos - Pour enregistrer des images -->
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>DonTroc peut enregistrer des images dans votre photothèque.</string>
	
	<!-- Localisation (en cours d'utilisation) - Pour afficher les annonces à proximité -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>DonTroc utilise votre position pour afficher les annonces à proximité et faciliter les échanges locaux.</string>
	
	<!-- Localisation (toujours) - Pour les notifications d'annonces à proximité -->
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>DonTroc utilise votre position pour vous notifier des nouvelles annonces à proximité.</string>
	
	<!-- Localisation (description par défaut pour iOS < 11) -->
	<key>NSLocationAlwaysUsageDescription</key>
	<string>DonTroc utilise votre position pour afficher les annonces à proximité.</string>
	
	<!-- Microphone - Pour les messages vocaux -->
	<key>NSMicrophoneUsageDescription</key>
	<string>DonTroc utilise le microphone pour enregistrer des messages vocaux dans la messagerie.</string>
	
	<!-- Calendrier - Pour les rappels de rendez-vous d'échange (optionnel) -->
	<key>NSCalendarsUsageDescription</key>
	<string>DonTroc peut créer des rappels pour vos rendez-vous d'échange.</string>
	
	<!-- Notifications -->
	<key>NSUserTrackingUsageDescription</key>
	<string>DonTroc utilise le suivi pour vous montrer des publicités pertinentes et améliorer votre expérience.</string>
	
	<!-- Face ID -->
	<key>NSFaceIDUsageDescription</key>
	<string>DonTroc peut utiliser Face ID pour sécuriser votre compte.</string>
	
