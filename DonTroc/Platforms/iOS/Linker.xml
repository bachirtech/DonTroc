<?xml version="1.0" encoding="UTF-8" ?>
<linker>
  <!-- Assembly principale -->
  <assembly fullname="DonTroc" preserve="all">
    <type fullname="DonTroc.ViewModels.*" preserve="all" />
    <type fullname="DonTroc.Services.*" preserve="all" />
    <type fullname="DonTroc.Models.*" preserve="all" />
    <type fullname="DonTroc.Views.*" preserve="all" />
    <type fullname="DonTroc.Converters.*" preserve="all" />
    <type fullname="DonTroc.Behaviors.*" preserve="all" />
    <type fullname="DonTroc.Configuration.*" preserve="all" />
    <type fullname="DonTroc.Extensions.*" preserve="all" />
    <type fullname="DonTroc.Platforms.iOS.*" preserve="all" />
  </assembly>

  <!-- Frameworks MAUI -->
  <assembly fullname="Microsoft.Maui.Controls" preserve="all" />
  <assembly fullname="Microsoft.Maui.Controls.Compatibility" preserve="all" />
  <assembly fullname="Microsoft.Maui.Essentials" preserve="all" />
  <assembly fullname="Microsoft.Maui.Graphics" preserve="all" />
  <assembly fullname="Microsoft.Maui.Controls.Maps" preserve="all" />

  <!-- CommunityToolkit -->
  <assembly fullname="CommunityToolkit.Mvvm" preserve="all" />
  <assembly fullname="CommunityToolkit.Maui" preserve="all" />
  <assembly fullname="CommunityToolkit.Maui.MediaElement" preserve="all" />

  <!-- Firebase (managed wrappers Plugin.Firebase) -->
  <assembly fullname="Plugin.Firebase" preserve="all" />
  <assembly fullname="Plugin.Firebase.Analytics" preserve="all" />
  <assembly fullname="Plugin.Firebase.Core" preserve="all" />
  <assembly fullname="Plugin.Firebase.Auth" preserve="all" />
  <assembly fullname="Plugin.Firebase.CloudMessaging" preserve="all" />
  <assembly fullname="Plugin.Firebase.Firestore" preserve="all" />
  <assembly fullname="Plugin.Firebase.Storage" preserve="all" />
  <assembly fullname="Plugin.Firebase.RemoteConfig" preserve="all" />
  <!-- Plugin.Firebase.Bundled : initialisation cross-platform Firebase -->
  <assembly fullname="Plugin.Firebase.Bundled" preserve="all" />
  <assembly fullname="Plugin.Firebase.Bundled.iOS" preserve="all" />
  <assembly fullname="Plugin.Firebase.Bundled.Shared" preserve="all" />
  <!-- Bindings natifs iOS Firebase (AdamE.* utilisé par Plugin.Firebase) -->
  <assembly fullname="Firebase.Auth" preserve="all" />
  <assembly fullname="Firebase.CloudMessaging" preserve="all" />
  <assembly fullname="Firebase.CloudFirestore" preserve="all" />
  <assembly fullname="Firebase.Database" preserve="all" />
  <assembly fullname="Firebase.Storage" preserve="all" />
  <assembly fullname="Firebase" preserve="all" />
  <!-- Bindings legacy (managed C# Firebase libs) -->
  <assembly fullname="FirebaseAuthentication.net" preserve="all" />
  <assembly fullname="FirebaseDatabase.net" preserve="all" />

  <!-- AdMob iOS (Jc.GMA.iOS = Google Mobile Ads binding) -->
  <assembly fullname="Jc.GMA.iOS" preserve="all" />
  <assembly fullname="Google.MobileAds" preserve="all" />

  <!-- JSON -->
  <assembly fullname="Newtonsoft.Json" preserve="all" />
  <assembly fullname="System.Text.Json" preserve="all" />

  <!-- Préserver les assemblages de cryptographie utilisés par les bindings natifs
       (évite que le linker/sx trimming supprime des types utilisés par
       AppleCryptoNative/X509 import lors de l'initialisation Firebase/AdMob) -->
  <assembly fullname="System.Security.Cryptography.Algorithms" preserve="all" />
  <assembly fullname="System.Security.Cryptography.Primitives" preserve="all" />
  <assembly fullname="System.Security.Cryptography.X509Certificates" preserve="all" />
  <assembly fullname="System.Net.Security" preserve="all" />
  <assembly fullname="Mono.Security" preserve="all" />

  <!-- Services tiers -->
  <assembly fullname="CloudinaryDotNet" preserve="all" />
  <assembly fullname="Plugin.Maui.Audio" preserve="all" />
  <assembly fullname="SixLabors.ImageSharp" preserve="all" />

  <!-- UI -->
  <assembly fullname="SkiaSharp" preserve="all" />
  <assembly fullname="SkiaSharp.Views.Maui.Controls" preserve="all" />
  <assembly fullname="Syncfusion.Maui.Core" preserve="all" />
  <assembly fullname="Syncfusion.Maui.ImageEditor" preserve="all" />

  <!-- DI -->
  <assembly fullname="Microsoft.Extensions.DependencyInjection" preserve="all" />
  <assembly fullname="Microsoft.Extensions.DependencyInjection.Abstractions" preserve="all" />
  <assembly fullname="Microsoft.Extensions.Caching.Memory" preserve="all" />

  <!-- Préserver les types liés à Firebase iOS natif -->
  <assembly fullname="Firebase.Analytics">
    <type fullname="Firebase.Analytics.*" preserve="all" />
  </assembly>
  <assembly fullname="Firebase.Core">
    <type fullname="Firebase.Core.*" preserve="all" />
  </assembly>
  /// preserver le script AppDelegate.cs qui contient l'initialisation Firebase iOS (Firebase.Core.App.Configure()) et la gestion des notifications push (Firebase.CloudMessaging) -->
    <assembly fullname="DonTroc.Platforms.iOS">
        <type fullname="DonTroc.Platforms.iOS.AppDelegate" preserve="all" />
    </assembly>
</linker>
