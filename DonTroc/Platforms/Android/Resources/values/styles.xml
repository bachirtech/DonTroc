<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Style de base pour le splash screen -->
    <style name="Maui.SplashTheme" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/maui_splash_color</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:statusBarColor">@color/maui_splash_color</item>
        <item name="android:navigationBarColor">@color/maui_splash_color</item>
    </style>
</resources>

