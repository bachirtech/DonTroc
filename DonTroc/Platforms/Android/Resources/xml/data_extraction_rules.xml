<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclure les données sensibles du backup cloud -->
        <exclude domain="sharedpref" path="secure_prefs.xml"/>
        <exclude domain="database" path="user_credentials.db"/>
        <exclude domain="file" path="keystore/"/>
    </cloud-backup>
    <device-transfer>
        <!-- Autoriser le transfert des données utilisateur non sensibles -->
        <include domain="sharedpref" path="user_preferences.xml"/>
        <include domain="file" path="cache/"/>
    </device-transfer>
</data-extraction-rules>

