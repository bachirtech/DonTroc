<?xml version="1.0" encoding="utf-8" ?>
<!-- Fichier: DonTroc/Views/DonationPopup.xaml -->
<!-- Popup élégant pour soutenir le développeur — Design DonTroc -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DonTroc.Views.DonationPopup"
             BackgroundColor="Transparent"
             Shell.PresentationMode="ModalAnimated">

    <Grid BackgroundColor="#90000000" Padding="20">

        <!-- ═══════════════════════════════════════════════ -->
        <!-- CARTE PRINCIPALE DU POPUP                       -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border BackgroundColor="{AppThemeBinding Light={StaticResource BeigeClair}, Dark={StaticResource BeigeSombre}}"
                StrokeShape="RoundRectangle 28,28,28,28"
                StrokeThickness="0"
                Padding="0"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                MaximumWidthRequest="420"
                MaximumHeightRequest="700">
            <Border.Shadow>
                <Shadow Brush="#60000000" Offset="0,8" Radius="24" Opacity="0.4" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,*">

                <!-- ═══ HEADER GRADIENT ═══ -->
                <Border Grid.Row="0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 28,28,0,0"
                        Padding="24,20,24,24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#8B5A3A}" Offset="0.0" />
                            <GradientStop Color="{AppThemeBinding Light=#C47A58, Dark=#6B4A32}" Offset="0.5" />
                            <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#5A7A3E}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>

                    <VerticalStackLayout Spacing="10">
                        <!-- Bouton fermer -->
                        <Border StrokeShape="RoundRectangle 16,16,16,16"
                                StrokeThickness="0"
                                BackgroundColor="#25FFFFFF"
                                WidthRequest="34" HeightRequest="34"
                                HorizontalOptions="End"
                                Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCloseClicked" />
                            </Border.GestureRecognizers>
                            <Label Text="✕"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Icône cœur -->
                        <Border StrokeShape="RoundRectangle 40,40,40,40"
                                StrokeThickness="0"
                                BackgroundColor="#30FFFFFF"
                                WidthRequest="80" HeightRequest="80"
                                HorizontalOptions="Center">
                            <Label Text="❤️"
                                   FontSize="40"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Titre -->
                        <Label Text="Soutenir le développeur"
                               FontSize="22"
                               FontAttributes="Bold"
                               FontFamily="PoppinsBold"
                               TextColor="White"
                               HorizontalTextAlignment="Center" />

                        <!-- Sous-titre -->
                        <Label Text="Votre soutien aide à garder DonTroc gratuit et à ajouter de nouvelles fonctionnalités ✨"
                               FontSize="13"
                               TextColor="#E0FFFFFF"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap" />
                    </VerticalStackLayout>
                </Border>

                <!-- ═══ CONTENU SCROLLABLE ═══ -->
                <ScrollView Grid.Row="1" Padding="20,16,20,20">
                    <VerticalStackLayout Spacing="14">

                        <!-- ─── SECTION DON FINANCIER ─── -->
                        <Label Text="💳 Faire un don"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />

                        <Label Text="Paiement simple par carte bancaire — Aucune inscription requise"
                               FontSize="11"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                               Opacity="0.6"
                               Margin="0,0,0,2" />

                        <!-- Bouton Ko-fi -->
                        <Border StrokeShape="RoundRectangle 16,16,16,16"
                                StrokeThickness="0"
                                Padding="0"
                                HeightRequest="56">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                                    <GradientStop Color="{AppThemeBinding Light=#E5A07E, Dark=#C47A58}" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#40D98C6A, Dark=#30000000}" Offset="0,3" Radius="10" Opacity="0.5" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnKofiClicked" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,0" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="☕" FontSize="22" VerticalTextAlignment="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                    <Label Text="Ko-fi"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Text="Carte bancaire directe"
                                           FontSize="10"
                                           TextColor="#D0FFFFFF" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="22" FontAttributes="Bold"
                                       TextColor="#B0FFFFFF" VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- Bouton PayPal -->
                        <Border StrokeShape="RoundRectangle 16,16,16,16"
                                StrokeThickness="0"
                                Padding="0"
                                HeightRequest="56">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{AppThemeBinding Light=#6B7A8F, Dark=#4A5A6F}" Offset="0.0" />
                                    <GradientStop Color="{AppThemeBinding Light=#8494A7, Dark=#5A6A7F}" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#306B7A8F, Dark=#25000000}" Offset="0,3" Radius="10" Opacity="0.5" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnPayPalClicked" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" Padding="18,0" ColumnSpacing="12">
                                <Label Grid.Column="0" Text="🅿️" FontSize="22" VerticalTextAlignment="Center" />
                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                    <Label Text="PayPal"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White" />
                                    <Label Text="Paiement sécurisé"
                                           FontSize="10"
                                           TextColor="#D0FFFFFF" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="22" FontAttributes="Bold"
                                       TextColor="#B0FFFFFF" VerticalTextAlignment="Center" />
                            </Grid>
                        </Border>

                        <!-- ─── SÉPARATEUR ─── -->
                        <Grid ColumnDefinitions="*,Auto,*" Margin="0,4">
                            <BoxView Grid.Column="0" HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light=#E8E0D8, Dark=#3D3326}"
                                     VerticalOptions="Center" />
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 10,10,10,10"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}"
                                    Padding="12,4"
                                    Margin="10,0">
                                <Label Text="ou gratuitement"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       Opacity="0.7" />
                            </Border>
                            <BoxView Grid.Column="2" HeightRequest="1"
                                     BackgroundColor="{AppThemeBinding Light=#E8E0D8, Dark=#3D3326}"
                                     VerticalOptions="Center" />
                        </Grid>

                        <!-- ─── SECTION SOUTIEN GRATUIT ─── -->
                        <Border StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                Padding="16,14">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#15A8C686, Dark=#20000000}" Offset="0,3" Radius="10" Opacity="0.4" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="12">
                                <!-- Titre section gratuite -->
                                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                    <Label Text="🌟" FontSize="18" VerticalTextAlignment="Center" />
                                    <Label Text="Aidez-moi gratuitement !"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>

                                <!-- Boutons Noter + Partager -->
                                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                                    <!-- Noter l'app -->
                                    <Border Grid.Column="0"
                                            StrokeShape="RoundRectangle 14,14,14,14"
                                            StrokeThickness="0"
                                            Padding="0"
                                            HeightRequest="50">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#8DAE6A}" Offset="0.0" />
                                                <GradientStop Color="{AppThemeBinding Light=#B8D696, Dark=#9ABE7A}" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Shadow>
                                            <Shadow Brush="{AppThemeBinding Light=#30A8C686, Dark=#20000000}" Offset="0,2" Radius="6" Opacity="0.4" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnRateAppClicked" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                                            <Label Text="⭐" FontSize="16" VerticalTextAlignment="Center" />
                                            <Label Text="Noter"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </Border>

                                    <!-- Partager -->
                                    <Border Grid.Column="1"
                                            StrokeShape="RoundRectangle 14,14,14,14"
                                            StrokeThickness="0"
                                            Padding="0"
                                            HeightRequest="50">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#8DAE6A}" Offset="0.0" />
                                                <GradientStop Color="{AppThemeBinding Light=#B8D696, Dark=#9ABE7A}" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.Shadow>
                                            <Shadow Brush="{AppThemeBinding Light=#30A8C686, Dark=#20000000}" Offset="0,2" Radius="6" Opacity="0.4" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnShareAppClicked" />
                                        </Border.GestureRecognizers>
                                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                                            <Label Text="📤" FontSize="16" VerticalTextAlignment="Center" />
                                            <Label Text="Partager"
                                                   FontSize="14"
                                                   FontAttributes="Bold"
                                                   TextColor="White"
                                                   VerticalTextAlignment="Center" />
                                        </HorizontalStackLayout>
                                    </Border>
                                </Grid>

                                <!-- Message -->
                                <Label Text="Votre avis sur le store et vos partages m'aident énormément !"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       Opacity="0.6"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- ─── MESSAGE FINAL ─── -->
                        <VerticalStackLayout Spacing="4" Margin="0,4,0,0" HorizontalOptions="Center">
                            <Label Text="Chaque geste compte 🙏"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Merci de faire partie de la communauté DonTroc !"
                                   FontSize="11"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                   Opacity="0.5"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>

