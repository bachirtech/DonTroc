<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             xmlns:models="clr-namespace:DonTroc.Models"
             xmlns:views="clr-namespace:DonTroc.Views"
             x:DataType="viewModels:AnnonceDetailViewModel"
             x:Class="DonTroc.Views.AnnonceDetailView"
             Title="Détail de l'annonce"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource BeigeClair}, Dark={StaticResource BeigeSombre}}">

    <!-- Intercepter le bouton retour Shell pour éviter "Ambiguous routes" -->
    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding GoBackCommand}" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="*">

        <!-- ═══════════════════════════════════════════════ -->
        <!-- LOADING STATE                                    -->
        <!-- ═══════════════════════════════════════════════ -->
        <VerticalStackLayout IsVisible="{Binding IsLoading}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="16">
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               Color="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                               WidthRequest="48" HeightRequest="48" />
            <Label Text="Chargement..."
                   FontSize="14"
                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- CONTENU PRINCIPAL                                -->
        <!-- ═══════════════════════════════════════════════ -->
        <ScrollView IsVisible="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
            <VerticalStackLayout Spacing="0">

                <!-- ════════════════════════════════════ -->
                <!-- SECTION PHOTOS (Carrousel)           -->
                <!-- ════════════════════════════════════ -->
                <Grid HeightRequest="320">
                    <!-- Placeholder si pas de photo -->
                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}">
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="6">
                            <Label Text="📷" FontSize="48" HorizontalTextAlignment="Center" />
                            <Label Text="Pas de photo disponible"
                                   FontSize="13"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                   Opacity="0.5"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Carrousel d'images -->
                    <CarouselView ItemsSource="{Binding Annonce.PhotosUrls}"
                                  CurrentItemChanged="OnCarouselPositionChanged"
                                  Loop="False"
                                  HeightRequest="320"
                                  HorizontalScrollBarVisibility="Never"
                                  IsVisible="{Binding Annonce.PhotosCount, Converter={StaticResource IntToBoolConverter}}">
                        <CarouselView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Image Source="{Binding .}"
                                       Aspect="AspectFill"
                                       HeightRequest="320">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:AnnonceDetailViewModel}}, Path=OpenImageViewerCommand}" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </DataTemplate>
                        </CarouselView.ItemTemplate>
                    </CarouselView>

                    <!-- Gradient bas pour lisibilité -->
                    <BoxView VerticalOptions="End" HeightRequest="80" InputTransparent="True">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0.0" />
                                <GradientStop Color="#70000000" Offset="1.0" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Bouton retour -->
                    <Border StrokeShape="RoundRectangle 20,20,20,20"
                            StrokeThickness="0"
                            BackgroundColor="#90000000"
                            WidthRequest="40" HeightRequest="40"
                            Margin="16,50,0,0"
                            HorizontalOptions="Start"
                            VerticalOptions="Start">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoBackCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="←" FontSize="20" TextColor="White"
                               HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                    </Border>

                    <!-- Badge Type en haut à droite -->
                    <Border StrokeShape="RoundRectangle 10,10,10,10"
                            StrokeThickness="0"
                            Padding="12,6"
                            Margin="0,50,16,0"
                            HorizontalOptions="End"
                            VerticalOptions="Start">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{AppThemeBinding Light=#E0D98C6A, Dark=#D0B8704E}" Offset="0.0" />
                                <GradientStop Color="{AppThemeBinding Light=#D0C47A58, Dark=#C0A06842}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Label Text="{Binding Annonce.Type}"
                               FontSize="13" FontAttributes="Bold" TextColor="White" />
                    </Border>

                    <!-- Indicateur de photo en bas à droite -->
                    <Border StrokeShape="RoundRectangle 8,8,8,8"
                            StrokeThickness="0"
                            BackgroundColor="#80000000"
                            Padding="8,4"
                            Margin="0,0,16,16"
                            HorizontalOptions="End"
                            VerticalOptions="End"
                            InputTransparent="True"
                            IsVisible="{Binding Annonce.PhotosCount, Converter={StaticResource IntToBoolConverter}}">
                        <Label Text="{Binding PhotoIndicatorText}"
                               TextColor="White" FontSize="12" FontAttributes="Bold" />
                    </Border>

                    <!-- Badge Boost -->
                    <Border StrokeShape="RoundRectangle 10,10,10,10"
                            StrokeThickness="0"
                            Padding="8,4"
                            Margin="16,0,0,16"
                            HorizontalOptions="Start"
                            VerticalOptions="End"
                            IsVisible="{Binding Annonce.IsBoosted}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#E0FF6B35" Offset="0.0" />
                                <GradientStop Color="#E0FF8F00" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Label Text="🚀 Boosté" FontSize="11" FontAttributes="Bold" TextColor="White" />
                    </Border>
                </Grid>

                <!-- ════════════════════════════════════ -->
                <!-- SECTION INFOS PRINCIPALES            -->
                <!-- ════════════════════════════════════ -->
                <VerticalStackLayout Padding="16,16,16,0" Spacing="12">

                    <!-- Titre -->
                    <Label Text="{Binding Annonce.Titre}"
                           FontSize="24"
                           FontAttributes="Bold"
                           FontFamily="PoppinsBold"
                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                           LineBreakMode="WordWrap" />

                    <!-- Bannière pub -->
                    <views:AdBannerView
                        HeightRequest="50"
                        MinimumHeightRequest="50"
                        HorizontalOptions="Fill"
                        BackgroundColor="Transparent" />

                    <!-- Badges : Catégorie + Statut + Date -->
                    <FlexLayout Wrap="Wrap" Direction="Row" AlignItems="Center"
                                JustifyContent="Start">
                        <!-- Catégorie -->
                        <Border StrokeShape="RoundRectangle 8,8,8,8"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=#F0F8E8, Dark=#2A3D22}"
                                Padding="10,5"
                                Margin="0,0,8,6">
                            <Label Text="{Binding Annonce.Categorie}"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}" />
                        </Border>
                        <!-- Statut -->
                        <Border StrokeShape="RoundRectangle 8,8,8,8"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=#EDE8F5, Dark=#2D273D}"
                                Padding="10,5"
                                Margin="0,0,8,6">
                            <Label Text="{Binding StatutFormatted}"
                                   FontSize="12" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                        </Border>
                        <!-- Date -->
                        <Label Text="{Binding DateCreationFormatted}"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                               Opacity="0.65"
                               VerticalTextAlignment="Center"
                               Margin="0,0,0,6" />
                    </FlexLayout>

                    <!-- Distance + Localisation -->
                    <Border StrokeShape="RoundRectangle 12,12,12,12"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#FFF8F0, Dark=#352C24}"
                            Padding="12,10"
                            IsVisible="{Binding HasLocation}">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📍" FontSize="16" VerticalTextAlignment="Center" />
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding LocationText}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                                <Label Text="{Binding Annonce.DistanceFormatted, StringFormat='à {0}'}"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       Opacity="0.7"
                                       IsVisible="{Binding Annonce.DistanceFromUser, Converter={StaticResource DistanceVisibilityConverter}}" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Description complète -->
                    <Border StrokeShape="RoundRectangle 14,14,14,14"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                            Padding="16,14">
                        <Border.Shadow>
                            <Shadow Brush="#10000000" Offset="0,2" Radius="8" Opacity="0.2" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="📝 Description"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                            <Label Text="{Binding Annonce.Description}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                   LineBreakMode="WordWrap"
                                   Opacity="0.85" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Section Troc (si applicable) -->
                    <Border StrokeShape="RoundRectangle 14,14,14,14"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#FFF3E8, Dark=#3D2E1E}"
                            Padding="16,14"
                            IsVisible="{Binding HasTrocDetails}">
                        <Border.Shadow>
                            <Shadow Brush="#10000000" Offset="0,2" Radius="8" Opacity="0.2" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="🔄 Recherche en échange"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />
                            <Label Text="{Binding Annonce.DescriptionRecherche}"
                                   FontSize="14"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                   LineBreakMode="WordWrap"
                                   Opacity="0.85" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <!-- ════════════════════════════════════ -->
                <!-- SECTION PUBLIEUR                      -->
                <!-- ════════════════════════════════════ -->
                <Border StrokeShape="RoundRectangle 16,16,16,16"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                        Margin="16,14,16,0"
                        Padding="16,14"
                        IsVisible="{Binding HasPublisherProfile}">
                    <Border.Shadow>
                        <Shadow Brush="#15000000" Offset="0,3" Radius="10" Opacity="0.3" />
                    </Border.Shadow>

                    <Grid ColumnDefinitions="56,*" ColumnSpacing="14">
                        <!-- Photo de profil -->
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 28,28,28,28"
                                StrokeThickness="0"
                                WidthRequest="56" HeightRequest="56"
                                BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}">
                            <Image Source="{Binding PublisherProfile.ProfilePictureUrl}"
                                   Aspect="AspectFill"
                                   WidthRequest="56" HeightRequest="56" />
                        </Border>

                        <!-- Infos -->
                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                            <Label Text="{Binding PublisherProfile.Name}"
                                   FontSize="16" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                            <Label Text="{Binding PublisherRatingStars}"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding PublisherMemberSince}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       Opacity="0.6" />
                                <Label FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}">
                                    <Label.Text>
                                        <Binding Path="PublisherProfile.NombreEchangesReussis"
                                                 StringFormat="{}{0} échange(s)" />
                                    </Label.Text>
                                </Label>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ════════════════════════════════════ -->
                <!-- BARRE D'ACTIONS                      -->
                <!-- ════════════════════════════════════ -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                      ColumnSpacing="10"
                      Margin="16,16,16,0"
                      RowDefinitions="Auto">                    <!-- Bouton Contacter (principal, large) -->
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 14,14,14,14"
                            StrokeThickness="0"
                            HeightRequest="50"
                            IsVisible="{Binding IsNotOwner}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                                <GradientStop Color="{AppThemeBinding Light=#C47A58, Dark=#A06842}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#40D98C6A, Dark=#40B8704E}"
                                   Offset="0,3" Radius="10" Opacity="0.4" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToChatCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                            <Label Text="💬" FontSize="20" VerticalTextAlignment="Center" />
                            <Label Text="Contacter" FontSize="16" FontAttributes="Bold"
                                   TextColor="White" VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- Bouton Favori -->
                    <Border Grid.Column="1"
                            x:Name="FavoriteBorder"
                            StrokeShape="RoundRectangle 14,14,14,14"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#FFF0F0, Dark=#3D2424}"
                            WidthRequest="50" HeightRequest="50">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFavoriteTapped" />
                        </Border.GestureRecognizers>
                        <Label FontSize="22"
                               HorizontalTextAlignment="Center" VerticalTextAlignment="Center">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding Annonce.IsFavorite}" Value="True">
                                    <Setter Property="Text" Value="❤️" />
                                </DataTrigger>
                                <DataTrigger TargetType="Label" Binding="{Binding Annonce.IsFavorite}" Value="False">
                                    <Setter Property="Text" Value="🤍" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>

                    <!-- Bouton Partager -->
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 14,14,14,14"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#E8F5E0, Dark=#2A3D22}"
                            WidthRequest="50" HeightRequest="50">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ShareCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="📤" FontSize="22"
                               HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                    </Border>

                    <!-- Bouton Signaler -->
                    <Border Grid.Column="3"
                            StrokeShape="RoundRectangle 14,14,14,14"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#FFF5F5, Dark=#3D2222}"
                            WidthRequest="50" HeightRequest="50"
                            IsVisible="{Binding IsNotOwner}">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ReportCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="⚠️" FontSize="22"
                               HorizontalTextAlignment="Center" VerticalTextAlignment="Center" />
                    </Border>
                </Grid>

                <!-- ════════════════════════════════════ -->
                <!-- BOUTON PROPOSER UN TROC              -->
                <!-- Visible uniquement pour annonces Troc -->
                <!-- ════════════════════════════════════ -->
                <Border StrokeShape="RoundRectangle 14,14,14,14"
                        StrokeThickness="0"
                        HeightRequest="52"
                        Margin="16,12,16,0"
                        IsVisible="{Binding CanProposeTrade}">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#8AA868}" Offset="0.0" />
                            <GradientStop Color="{AppThemeBinding Light=#8AA868, Dark=#6E8A50}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#40A8C686, Dark=#408AA868}"
                                Offset="0,3" Radius="10" Opacity="0.4" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ProposeTradeCommand}" />
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                        <Label Text="🔄" FontSize="20" VerticalTextAlignment="Center" />
                        <Label Text="Proposer un troc" FontSize="16" FontAttributes="Bold"
                               FontFamily="PoppinsBold"
                               TextColor="White" VerticalTextAlignment="Center" />
                    </HorizontalStackLayout>
                </Border>

                <!-- ════════════════════════════════════ -->
                <!-- ANNONCES SIMILAIRES                   -->
                <!-- ════════════════════════════════════ -->
                <VerticalStackLayout Margin="0,20,0,0"
                                     IsVisible="{Binding SimilarAnnonces.Count, Converter={StaticResource IntToBoolConverter}}">

                    <Label Text="🔗 Annonces similaires"
                           FontSize="18" FontAttributes="Bold"
                           FontFamily="PoppinsBold"
                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                           Margin="16,0,0,10" />

                    <CollectionView ItemsSource="{Binding SimilarAnnonces}"
                                    HeightRequest="210"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal"
                                               ItemSpacing="12" />
                        </CollectionView.ItemsLayout>

                        <CollectionView.Header>
                            <BoxView WidthRequest="16" BackgroundColor="Transparent" />
                        </CollectionView.Header>

                        <CollectionView.Footer>
                            <BoxView WidthRequest="16" BackgroundColor="Transparent" />
                        </CollectionView.Footer>

                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:Annonce">
                                <Border StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                        WidthRequest="160"
                                        Padding="0">
                                    <Border.Shadow>
                                        <Shadow Brush="#20000000" Offset="0,2" Radius="8" Opacity="0.3" />
                                    </Border.Shadow>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:AnnonceDetailViewModel}}, Path=NavigateToSimilarCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid RowDefinitions="120,Auto" RowSpacing="0">
                                        <!-- Image miniature -->
                                        <Border Grid.Row="0"
                                                StrokeThickness="0"
                                                StrokeShape="RoundRectangle 14,14,0,0"
                                                BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}">
                                            <Image Source="{Binding FirstPhotoUrl}"
                                                   Aspect="AspectFill"
                                                   HeightRequest="120" />
                                        </Border>

                                        <!-- Badge Type -->
                                        <Border Grid.Row="0"
                                                StrokeShape="RoundRectangle 6,6,6,6"
                                                StrokeThickness="0"
                                                Padding="6,3"
                                                Margin="6,6,0,0"
                                                HorizontalOptions="Start"
                                                VerticalOptions="Start"
                                                BackgroundColor="{AppThemeBinding Light=#E0D98C6A, Dark=#D0B8704E}">
                                            <Label Text="{Binding Type}" FontSize="10"
                                                   FontAttributes="Bold" TextColor="White" />
                                        </Border>

                                        <!-- Infos -->
                                        <VerticalStackLayout Grid.Row="1" Padding="10,8" Spacing="3">
                                            <Label Text="{Binding Titre}"
                                                   FontSize="13" FontAttributes="Bold"
                                                   MaxLines="1" LineBreakMode="TailTruncation"
                                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                                            <Label Text="{Binding Categorie}"
                                                   FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Espace en bas -->
                <BoxView HeightRequest="30" BackgroundColor="Transparent" />

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>

