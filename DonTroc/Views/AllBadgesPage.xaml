<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:DonTroc.ViewModels"
             x:Class="DonTroc.Views.AllBadgesPage"
             x:DataType="viewmodels:AllBadgesViewModel"
             Title="Tous les Badges"
             BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocBackground}, Dark={StaticResource DonTrocBackgroundDark}}">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior IsVisible="True" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="Auto,Auto,*">
        
        <!-- Header avec progression globale -->
        <Border Grid.Row="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocPrimary}, Dark={StaticResource DonTrocPrimaryDark}}"
                Padding="20"
                Margin="0,0,0,10">
            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto">
                
                <!-- Titre et compteur -->
                <StackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                    <Label Text="🏆 Collection de Badges"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label Text="Débloquez des badges en utilisant l'application !"
                           FontSize="14" 
                           TextColor="White" 
                           Opacity="0.9"/>
                </StackLayout>
                
                <!-- Compteur de badges -->
                <Border Grid.Row="0" Grid.Column="1"
                        BackgroundColor="#40FFFFFF"
                        StrokeShape="RoundRectangle 12"
                        Padding="12,8"
                        VerticalOptions="Center">
                    <StackLayout Orientation="Horizontal" Spacing="5">
                        <Label Text="🎖️" FontSize="18"/>
                        <Label Text="{Binding BadgeCountText}"
                               TextColor="White" 
                               FontAttributes="Bold" 
                               FontSize="16" 
                               VerticalOptions="Center"/>
                    </StackLayout>
                </Border>
                
                <!-- Barre de progression globale -->
                <Grid Grid.Row="1" Grid.ColumnSpan="2" Margin="0,15,0,0">
                    <Border BackgroundColor="#40FFFFFF"
                            StrokeShape="RoundRectangle 6"
                            HeightRequest="12"/>
                    <Border BackgroundColor="#FFD54F"
                            StrokeShape="RoundRectangle 6"
                            HeightRequest="12"
                            HorizontalOptions="Start"
                            WidthRequest="{Binding ProgressBarWidth}"/>
                </Grid>
                
                <Label Grid.Row="2" Grid.ColumnSpan="2"
                       Text="{Binding ProgressText}"
                       TextColor="White"
                       FontSize="12"
                       Opacity="0.9"
                       HorizontalOptions="Center"
                       Margin="0,8,0,0"/>
            </Grid>
        </Border>
        
        <!-- Barre de recherche et filtres -->
        <VerticalStackLayout Grid.Row="1" Spacing="10" Padding="15,5,15,10">
            
            <!-- Barre de recherche -->
            <Border BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                    StrokeShape="RoundRectangle 10"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    Padding="10,5">
                <Grid ColumnDefinitions="Auto,*">
                    <Label Grid.Column="0" Text="🔍" FontSize="18" VerticalOptions="Center" Margin="0,0,10,0"/>
                    <Entry Grid.Column="1"
                           Placeholder="Rechercher un badge..."
                           Text="{Binding SearchText}"
                           FontSize="15"
                           VerticalOptions="Center"/>
                </Grid>
            </Border>
            
            <!-- Filtres par catégorie (scroll horizontal) -->
            <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="8">
                    <!-- Bouton Tous -->
                    <Border BackgroundColor="{AppThemeBinding Light=#E8F5E9, Dark=#1B5E20}"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="Tous"/>
                        </Border.GestureRecognizers>
                        <Label Text="📋 Tous"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#2E7D32, Dark=#A5D6A7}"/>
                    </Border>
                    
                    <!-- Catégorie Donateur -->
                    <Border BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#E65100}"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="🎁 Donateur"/>
                        </Border.GestureRecognizers>
                        <Label Text="🎁 Donateur"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#E65100, Dark=#FFCC80}"/>
                    </Border>
                    
                    <!-- Catégorie Receveur -->
                    <Border BackgroundColor="{AppThemeBinding Light=#FCE4EC, Dark=#880E4F}"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="🎀 Receveur"/>
                        </Border.GestureRecognizers>
                        <Label Text="🎀 Receveur"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#880E4F, Dark=#F48FB1}"/>
                    </Border>
                    
                    <!-- Catégorie Social -->
                    <Border BackgroundColor="{AppThemeBinding Light=#E3F2FD, Dark=#0D47A1}"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="💬 Social"/>
                        </Border.GestureRecognizers>
                        <Label Text="💬 Social"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#0D47A1, Dark=#90CAF9}"/>
                    </Border>
                    
                    <!-- Catégorie Explorateur -->
                    <Border BackgroundColor="{AppThemeBinding Light=#E8EAF6, Dark=#283593}"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="🗺️ Explorateur"/>
                        </Border.GestureRecognizers>
                        <Label Text="🗺️ Explorateur"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#283593, Dark=#9FA8DA}"/>
                    </Border>
                    
                    <!-- Catégorie Vétéran -->
                    <Border BackgroundColor="{AppThemeBinding Light=#FFFDE7, Dark=#F57F17}"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="🏆 Vétéran"/>
                        </Border.GestureRecognizers>
                        <Label Text="🏆 Vétéran"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#F57F17, Dark=#FFF59D}"/>
                    </Border>
                    
                    <!-- Catégorie Spécial -->
                    <Border BackgroundColor="{AppThemeBinding Light=#F3E5F5, Dark=#6A1B9A}"
                            StrokeShape="RoundRectangle 20"
                            Padding="12,8">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterByCategoryCommand}" CommandParameter="✨ Spécial"/>
                        </Border.GestureRecognizers>
                        <Label Text="✨ Spécial"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#6A1B9A, Dark=#CE93D8}"/>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>
        </VerticalStackLayout>
        
        <!-- Liste des badges groupés -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Spacing="15" Padding="15,5,15,20"
                                 BindableLayout.ItemsSource="{Binding BadgeGroups}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:BadgeCategoryGroup">
                        <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                                StrokeShape="RoundRectangle 15"
                                Stroke="Transparent"
                                Padding="15">
                            <StackLayout Spacing="12">
                                
                                <!-- En-tête de catégorie -->
                                <Label Text="{Binding CategoryName}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#6B7A8F, Dark=#9BB0C7}"/>
                                
                                <!-- Liste des badges de cette catégorie -->
                                <FlexLayout Wrap="Wrap"
                                            JustifyContent="Start"
                                            AlignItems="Start"
                                            BindableLayout.ItemsSource="{Binding Badges}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="viewmodels:BadgeDisplayItem">
                                            <Border WidthRequest="165"
                                                    HeightRequest="190"
                                                    BackgroundColor="{Binding RarityBackgroundColor}"
                                                    StrokeShape="RoundRectangle 12"
                                                    Stroke="{Binding RarityColor}"
                                                    StrokeThickness="2"
                                                    Padding="10"
                                                    Margin="3"
                                                    Opacity="{Binding Opacity}">
                                                <StackLayout Spacing="3" VerticalOptions="Center">
                                                    
                                                    <!-- Icône du badge -->
                                                    <Label Text="{Binding DisplayIcon}"
                                                           FontSize="40"
                                                           HorizontalOptions="Center"/>
                                                    
                                                    <!-- Nom du badge -->
                                                    <Label Text="{Binding DisplayName}"
                                                           FontSize="12"
                                                           FontAttributes="Bold"
                                                           HorizontalOptions="Center"
                                                           HorizontalTextAlignment="Center"
                                                           MaxLines="2"
                                                           LineBreakMode="TailTruncation"
                                                           TextColor="{AppThemeBinding Light=#6B7A8F, Dark=#9BB0C7}"/>
                                                    
                                                    <!-- Description -->
                                                    <Label Text="{Binding DisplayDescription}"
                                                           FontSize="10"
                                                           HorizontalOptions="Center"
                                                           HorizontalTextAlignment="Center"
                                                           MaxLines="2"
                                                           LineBreakMode="TailTruncation"
                                                           TextColor="{AppThemeBinding Light=#404040, Dark=#919191}"/>
                                                    
                                                    <!-- Rareté et XP -->
                                                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                                                        <Border BackgroundColor="{Binding RarityColor}"
                                                                StrokeShape="RoundRectangle 8"
                                                                Padding="6,2">
                                                            <Label Text="{Binding RarityName}"
                                                                   FontSize="9"
                                                                   TextColor="White"/>
                                                        </Border>
                                                        <Label Text="{Binding XpReward, StringFormat='+{0} XP'}"
                                                               FontSize="10"
                                                               TextColor="#4CAF50"
                                                               FontAttributes="Bold"
                                                               VerticalOptions="Center"/>
                                                    </HorizontalStackLayout>
                                                    
                                                    <!-- Indicateur débloqué/verrouillé -->
                                                    <Label Text="{Binding UnlockedStatusText}"
                                                           FontSize="10"
                                                           HorizontalOptions="Center"
                                                           TextColor="{Binding UnlockedStatusColor}"/>
                                                </StackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </FlexLayout>
                            </StackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </ScrollView>
        
        <!-- Indicateur de chargement -->
        <ActivityIndicator Grid.RowSpan="3"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource DonTrocPrimary}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
    </Grid>
</ContentPage>

