<?xml version="1.0" encoding="utf-8" ?>
<!-- Fichier: DonTroc/Views/ProfilView.xaml -->

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             xmlns:models="clr-namespace:DonTroc.Models"
             xmlns:views="clr-namespace:DonTroc.Views"
             xmlns:converters="clr-namespace:DonTroc.Converters"
             x:DataType="viewModels:ProfilViewModel"
             x:Class="DonTroc.Views.ProfilView"
             Title="Mon Profil"
             BackgroundColor="{AppThemeBinding Light={StaticResource BeigeClair}, Dark={StaticResource BeigeSombre}}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:NoteToStarsConverter x:Key="NoteToStarsConverter" />
            <converters:BadgeConfianceToTextConverter x:Key="BadgeConfianceToTextConverter" />
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView x:Name="ProfilScrollView">
            <VerticalStackLayout Spacing="0">

                <!-- ═══════════════════════════════════════════════ -->
                <!-- HERO HEADER : Avatar + Nom + Badge             -->
                <!-- ═══════════════════════════════════════════════ -->
                <Border x:Name="ProfilHeaderBorder"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 0,0,32,32"
                        Padding="20,15,20,30">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#8B5A3A}" Offset="0.0" />
                            <GradientStop Color="{AppThemeBinding Light=#C47A58, Dark=#6B4A32}" Offset="0.5" />
                            <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#5A7A3E}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#40000000" Offset="0,6" Radius="16" Opacity="0.3" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="16">
                        <!-- Bannière pub -->
                        <views:AdBannerView
                            HeightRequest="50"
                            MinimumHeightRequest="50"
                            HorizontalOptions="Fill"
                            BackgroundColor="Transparent" />

                        <!-- Avatar + Infos -->
                        <VerticalStackLayout Spacing="12" HorizontalOptions="Center">

                            <!-- Avatar avec bordure dorée -->
                            <Border StrokeShape="RoundRectangle 50,50,50,50"
                                    StrokeThickness="3"
                                    Stroke="#80FFFFFF"
                                    WidthRequest="100" HeightRequest="100"
                                    HorizontalOptions="Center">
                                <Border.Shadow>
                                    <Shadow Brush="#50000000" Offset="0,4" Radius="12" Opacity="0.4" />
                                </Border.Shadow>
                                <Image Source="{Binding UserProfile.ProfilePictureUrl}"
                                       Aspect="AspectFill"
                                       WidthRequest="100" HeightRequest="100" />
                            </Border>

                            <!-- Nom d'utilisateur -->
                            <Label Text="{Binding UserProfile.Name}"
                                   FontSize="24"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   FontFamily="PoppinsBold"
                                   HorizontalTextAlignment="Center" />

                            <!-- Email -->
                            <Label Text="{Binding UserEmail}"
                                   FontSize="13"
                                   TextColor="#D0FFFFFF"
                                   HorizontalTextAlignment="Center" />

                            <!-- Badge de confiance -->
                            <Border StrokeShape="RoundRectangle 14,14,14,14"
                                    StrokeThickness="0"
                                    BackgroundColor="#30FFFFFF"
                                    Padding="16,6"
                                    HorizontalOptions="Center">
                                <HorizontalStackLayout Spacing="6" HorizontalOptions="Center">
                                    <Label Text="{Binding UserProfile.Badge, Converter={StaticResource BadgeConfianceToTextConverter}}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Membre depuis -->
                            <Label FontSize="11"
                                   TextColor="#B0FFFFFF"
                                   HorizontalTextAlignment="Center">
                                <Label.Text>
                                    <Binding Path="UserProfile.DateInscription"
                                             StringFormat="Membre depuis {0:MMMM yyyy}" />
                                </Label.Text>
                            </Label>
                        </VerticalStackLayout>

                        <!-- Mini Stats en ligne -->
                        <Grid ColumnDefinitions="*,Auto,*,Auto,*" Margin="0,4,0,0">
                            <!-- Note -->
                            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding UserProfile.NoteMoyenne, StringFormat='{0:F1}'}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="⭐ Note"
                                       FontSize="11"
                                       TextColor="#C0FFFFFF"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <!-- Séparateur -->
                            <BoxView Grid.Column="1"
                                     WidthRequest="1" HeightRequest="30"
                                     BackgroundColor="#40FFFFFF"
                                     VerticalOptions="Center" />

                            <!-- Échanges -->
                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding UserProfile.NombreEchangesReussis}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="🤝 Échanges"
                                       FontSize="11"
                                       TextColor="#C0FFFFFF"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <!-- Séparateur -->
                            <BoxView Grid.Column="3"
                                     WidthRequest="1" HeightRequest="30"
                                     BackgroundColor="#40FFFFFF"
                                     VerticalOptions="Center" />

                            <!-- Points -->
                            <VerticalStackLayout Grid.Column="4" HorizontalOptions="Center" Spacing="2">
                                <Label Text="{Binding UserProfile.Points}"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="🏆 Points"
                                       FontSize="11"
                                       TextColor="#C0FFFFFF"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══════════════════════════════════════════════ -->
                <!-- CONTENU PRINCIPAL (sous le header)              -->
                <!-- ═══════════════════════════════════════════════ -->
                <VerticalStackLayout Padding="18,0,18,20" Spacing="18" Margin="0,-14,0,0">

                    <!-- ─── ACTIONS PRINCIPALES ─── -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">

                        <!-- Modifier le profil -->
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                Padding="12,16"
                                HeightRequest="100">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#20D98C6A, Dark=#20000000}" Offset="0,3" Radius="10" Opacity="0.5" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EditProfileCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#FFEDE3, Dark=#3D2E24}"
                                        WidthRequest="42" HeightRequest="42"
                                        HorizontalOptions="Center">
                                    <Label Text="✏️" FontSize="20"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Modifier"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Messages -->
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                Padding="12,16"
                                HeightRequest="100">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#20A8C686, Dark=#20000000}" Offset="0,3" Radius="10" Opacity="0.5" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToConversationsCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E8F5E0, Dark=#2A3D22}"
                                        WidthRequest="42" HeightRequest="42"
                                        HorizontalOptions="Center">
                                    <Label Text="💬" FontSize="20"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Messages"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Soutenir -->
                        <Border Grid.Column="2"
                                StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                Padding="12,16"
                                HeightRequest="100">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#206B7A8F, Dark=#20000000}" Offset="0,3" Radius="10" Opacity="0.5" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DonateToDevCommand}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center" VerticalOptions="Center">
                                <Border StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#FFF0F0, Dark=#3D2424}"
                                        WidthRequest="42" HeightRequest="42"
                                        HorizontalOptions="Center">
                                    <Label Text="❤️" FontSize="20"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Soutenir"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- ─── ACCÈS RAPIDE ─── -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Accès rapide"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                               Margin="4,0,0,0" />

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                            <!-- Carte -->
                            <Border Grid.Column="0" Grid.Row="0"
                                    StrokeShape="RoundRectangle 16,16,16,16"
                                    StrokeThickness="0"
                                    Padding="0"
                                    HeightRequest="56">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#E5A07E, Dark=#C47A58}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#35D98C6A, Dark=#25000000}" Offset="0,3" Radius="8" Opacity="0.5" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToMapCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="10" Padding="16,0" VerticalOptions="Center">
                                    <Label Text="🗺️" FontSize="20" VerticalTextAlignment="Center" />
                                    <Label Text="Carte"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Transactions -->
                            <Border Grid.Column="1" Grid.Row="0"
                                    StrokeShape="RoundRectangle 16,16,16,16"
                                    StrokeThickness="0"
                                    Padding="0"
                                    HeightRequest="56">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#8DAE6A}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#B8D696, Dark=#9ABE7A}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#35A8C686, Dark=#25000000}" Offset="0,3" Radius="8" Opacity="0.5" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToTransactionsCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="10" Padding="16,0" VerticalOptions="Center">
                                    <Label Text="📋" FontSize="20" VerticalTextAlignment="Center" />
                                    <Label Text="Transactions"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Récompenses -->
                            <Border Grid.Column="0" Grid.Row="1"
                                    StrokeShape="RoundRectangle 16,16,16,16"
                                    StrokeThickness="0"
                                    Padding="0"
                                    HeightRequest="56">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#6B7A8F, Dark=#4A5A6F}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#8494A7, Dark=#5A6A7F}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#356B7A8F, Dark=#25000000}" Offset="0,3" Radius="8" Opacity="0.5" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToRewardsCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="10" Padding="16,0" VerticalOptions="Center">
                                    <Label Text="🏆" FontSize="20" VerticalTextAlignment="Center" />
                                    <Label Text="Récompenses"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Admin (visible seulement pour admin/modérateur) -->
                            <Border Grid.Column="1" Grid.Row="1"
                                    StrokeShape="RoundRectangle 16,16,16,16"
                                    StrokeThickness="0"
                                    Padding="0"
                                    HeightRequest="56"
                                    IsVisible="{Binding IsAdminOrModerator}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#E53935, Dark=#C62828}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#EF5350, Dark=#D32F2F}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#35E53935, Dark=#25000000}" Offset="0,3" Radius="8" Opacity="0.5" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToAdminCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="10" Padding="16,0" VerticalOptions="Center">
                                    <Label Text="🛡️" FontSize="20" VerticalTextAlignment="Center" />
                                    <Label Text="Admin"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Amis & Parrainage -->
                            <Border Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2"
                                    StrokeShape="RoundRectangle 16,16,16,16"
                                    StrokeThickness="0"
                                    Padding="0"
                                    HeightRequest="56">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#C4956A, Dark=#A67A4E}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#D4A57A, Dark=#B88A58}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#35C4956A, Dark=#25000000}" Offset="0,3" Radius="8" Opacity="0.5" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding NavigateToSocialCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="10" Padding="16,0" VerticalOptions="Center" HorizontalOptions="Center">
                                    <Label Text="👥" FontSize="20" VerticalTextAlignment="Center" />
                                    <Label Text="Amis &amp; Parrainage"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalTextAlignment="Center" />
                                </HorizontalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- ─── ÉVALUATIONS & AVIS ─── -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Évaluations récentes"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                               Margin="4,0,0,0" />

                        <!-- Carte résumé note -->
                        <Border StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                Padding="18,16">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#18000000, Dark=#25000000}" Offset="0,3" Radius="10" Opacity="0.4" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                <!-- Grande note -->
                                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding UserProfile.NoteMoyenne, StringFormat='{0:F1}'}"
                                           FontSize="36"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding UserProfile.NoteMoyenne, Converter={StaticResource NoteToStarsConverter}}"
                                           FontSize="14"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding UserProfile.NombreEvaluations, StringFormat='{0} avis'}"
                                           FontSize="11"
                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                           Opacity="0.7"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>

                                <!-- Derniers commentaires -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4">
                                    <!-- Liste via BindableLayout -->
                                    <VerticalStackLayout Spacing="6"
                                                         BindableLayout.ItemsSource="{Binding UserProfile.DernieresEvaluations}">
                                        <BindableLayout.ItemTemplate>
                                            <DataTemplate x:DataType="models:Rating">
                                                <VerticalStackLayout Spacing="2" Padding="0,2">
                                                    <HorizontalStackLayout Spacing="6">
                                                        <Label Text="{Binding NomEvaluateur}"
                                                               FontSize="12"
                                                               FontAttributes="Bold"
                                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                                               LineBreakMode="TailTruncation"
                                                               MaxLines="1" />
                                                        <Label Text="{Binding Note, Converter={StaticResource NoteToStarsConverter}}"
                                                               FontSize="10"
                                                               VerticalTextAlignment="Center" />
                                                    </HorizontalStackLayout>
                                                    <Label Text="{Binding Commentaire}"
                                                           FontSize="11"
                                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                                           Opacity="0.7"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1" />
                                                </VerticalStackLayout>
                                            </DataTemplate>
                                        </BindableLayout.ItemTemplate>
                                    </VerticalStackLayout>

                                    <!-- Message si aucune évaluation (quand NombreEvaluations = 0) -->
                                    <Label Text="Aucun avis pour le moment"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                           Opacity="0.5"
                                           VerticalOptions="Center" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ─── SÉLECTEUR DE THÈME ─── -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Apparence"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                               Margin="4,0,0,0" />

                        <Border StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                Padding="6">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#18000000, Dark=#25000000}" Offset="0,3" Radius="10" Opacity="0.4" />
                            </Border.Shadow>

                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="6">
                                <!-- Clair -->
                                <Border Grid.Column="0"
                                        StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="2"
                                        Stroke="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}"
                                        Padding="10,14"
                                        Opacity="{Binding IsLightThemeSelected, Converter={StaticResource BoolToOpacityConverter}}">
                                    <Border.BackgroundColor>
                                        <Binding Path="IsLightThemeSelected">
                                            <Binding.Converter>
                                                <converters:BoolToColorConverter />
                                            </Binding.Converter>
                                            <Binding.ConverterParameter>#25D98C6A|#00000000</Binding.ConverterParameter>
                                        </Binding>
                                    </Border.BackgroundColor>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectThemeCommand}"
                                                              CommandParameter="light" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="☀️" FontSize="24" HorizontalTextAlignment="Center" />
                                        <Label Text="Clair"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Sombre -->
                                <Border Grid.Column="1"
                                        StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="2"
                                        Stroke="{AppThemeBinding Light=#6B7A8F, Dark=#9BB0C7}"
                                        Padding="10,14"
                                        Opacity="{Binding IsDarkThemeSelected, Converter={StaticResource BoolToOpacityConverter}}">
                                    <Border.BackgroundColor>
                                        <Binding Path="IsDarkThemeSelected">
                                            <Binding.Converter>
                                                <converters:BoolToColorConverter />
                                            </Binding.Converter>
                                            <Binding.ConverterParameter>#256B7A8F|#00000000</Binding.ConverterParameter>
                                        </Binding>
                                    </Border.BackgroundColor>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectThemeCommand}"
                                                              CommandParameter="dark" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="🌙" FontSize="24" HorizontalTextAlignment="Center" />
                                        <Label Text="Sombre"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Auto -->
                                <Border Grid.Column="2"
                                        StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="2"
                                        Stroke="{AppThemeBinding Light=#A8C686, Dark=#8DAE6A}"
                                        Padding="10,14"
                                        Opacity="{Binding IsSystemThemeSelected, Converter={StaticResource BoolToOpacityConverter}}">
                                    <Border.BackgroundColor>
                                        <Binding Path="IsSystemThemeSelected">
                                            <Binding.Converter>
                                                <converters:BoolToColorConverter />
                                            </Binding.Converter>
                                            <Binding.ConverterParameter>#25A8C686|#00000000</Binding.ConverterParameter>
                                        </Binding>
                                    </Border.BackgroundColor>
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding SelectThemeCommand}"
                                                              CommandParameter="system" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="🔄" FontSize="24" HorizontalTextAlignment="Center" />
                                        <Label Text="Auto"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ─── MES PROPOSITIONS DE TROC ─── -->
                    <Border StrokeShape="RoundRectangle 16,16,16,16"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="56">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#8AA868}" Offset="0.0" />
                                <GradientStop Color="{AppThemeBinding Light=#8AA868, Dark=#6E8A50}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#35A8C686, Dark=#258AA868}" Offset="0,3" Radius="8" Opacity="0.5" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding NavigateToTradeProposalsCommand}" />
                        </Border.GestureRecognizers>
                        <HorizontalStackLayout Spacing="10" Padding="16,0" VerticalOptions="Center" HorizontalOptions="Center">
                            <Label Text="🔄" FontSize="20" VerticalTextAlignment="Center" />
                            <Label Text="Mes propositions de troc"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalTextAlignment="Center" />
                        </HorizontalStackLayout>
                    </Border>

                    <!-- ─── MES ANNONCES ─── -->
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="8" Margin="4,0,0,0">
                            <Label Text="Mes annonces"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                   VerticalTextAlignment="Center" />
                            <Border StrokeShape="RoundRectangle 10,10,10,10"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#FFEDE3, Dark=#3D2E24}"
                                    Padding="8,3">
                                <Label Text="{Binding MesAnnonces.Count}"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />
                            </Border>
                        </HorizontalStackLayout>

                        <!-- Liste d'annonces -->
                        <CollectionView ItemsSource="{Binding MesAnnonces}"
                                        SelectionMode="None"
                                        HeightRequest="400">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Annonce">
                                    <Border StrokeShape="RoundRectangle 16,16,16,16"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                            Padding="0">
                                        <Border.Shadow>
                                            <Shadow Brush="{AppThemeBinding Light=#18000000, Dark=#25000000}" Offset="0,2" Radius="8" Opacity="0.4" />
                                        </Border.Shadow>

                                        <Grid ColumnDefinitions="90,*" RowDefinitions="Auto" ColumnSpacing="0">
                                            <!-- Image miniature -->
                                            <Border Grid.Column="0"
                                                    StrokeShape="RoundRectangle 16,0,0,16"
                                                    StrokeThickness="0"
                                                    BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}"
                                                    HeightRequest="100">
                                                <Image Source="{Binding FirstPhotoUrl}"
                                                       Aspect="AspectFill"
                                                       HeightRequest="100"
                                                       WidthRequest="90" />
                                            </Border>

                                            <!-- Infos + Actions -->
                                            <Grid Grid.Column="1"
                                                  RowDefinitions="Auto,Auto,Auto"
                                                  Padding="12,10,10,10"
                                                  RowSpacing="4">

                                                <!-- Titre + Type -->
                                                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" ColumnSpacing="6">
                                                    <Label Grid.Column="0"
                                                           Text="{Binding Titre}"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                                           LineBreakMode="TailTruncation"
                                                           MaxLines="1" />
                                                    <Border Grid.Column="1"
                                                            StrokeShape="RoundRectangle 6,6,6,6"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{AppThemeBinding Light=#FFEDE3, Dark=#3D2E24}"
                                                            Padding="6,2">
                                                        <Label Text="{Binding Type}"
                                                               FontSize="10"
                                                               FontAttributes="Bold"
                                                               TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />
                                                    </Border>
                                                </Grid>

                                                <!-- Catégorie + Date -->
                                                <HorizontalStackLayout Grid.Row="1" Spacing="8">
                                                    <Label Text="{Binding Categorie}"
                                                           FontSize="11"
                                                           TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}"
                                                           FontAttributes="Bold" />
                                                    <Label Text="{Binding DateCreation, StringFormat='{0:dd/MM/yyyy}'}"
                                                           FontSize="11"
                                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                                           Opacity="0.6" />
                                                </HorizontalStackLayout>

                                                <!-- Boutons d'action -->
                                                <HorizontalStackLayout Grid.Row="2" Spacing="6" Margin="0,4,0,0">
                                                    <!-- Modifier -->
                                                    <Border StrokeShape="RoundRectangle 10,10,10,10"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{AppThemeBinding Light=#E8F5E0, Dark=#2A3D22}"
                                                            Padding="0"
                                                            WidthRequest="34" HeightRequest="34">
                                                        <Button Text="✏️"
                                                                FontSize="14"
                                                                Clicked="OnEditAnnonceClicked"
                                                                BindingContext="{Binding .}"
                                                                BackgroundColor="Transparent"
                                                                WidthRequest="34" HeightRequest="34"
                                                                CornerRadius="10"
                                                                Padding="0" />
                                                    </Border>

                                                    <!-- Booster -->
                                                    <Border StrokeShape="RoundRectangle 10,10,10,10"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{AppThemeBinding Light=#FFF5E6, Dark=#3D3222}"
                                                            Padding="0"
                                                            WidthRequest="34" HeightRequest="34">
                                                        <Button Text="🚀"
                                                                FontSize="14"
                                                                Clicked="OnBoostAnnonceClicked"
                                                                BindingContext="{Binding .}"
                                                                BackgroundColor="Transparent"
                                                                WidthRequest="34" HeightRequest="34"
                                                                CornerRadius="10"
                                                                Padding="0" />
                                                    </Border>

                                                    <!-- Supprimer -->
                                                    <Border StrokeShape="RoundRectangle 10,10,10,10"
                                                            StrokeThickness="0"
                                                            BackgroundColor="{AppThemeBinding Light=#FFF0F0, Dark=#3D2424}"
                                                            Padding="0"
                                                            WidthRequest="34" HeightRequest="34">
                                                        <Button Text="🗑️"
                                                                FontSize="14"
                                                                Clicked="OnDeleteAnnonceClicked"
                                                                BindingContext="{Binding .}"
                                                                BackgroundColor="Transparent"
                                                                WidthRequest="34" HeightRequest="34"
                                                                CornerRadius="10"
                                                                Padding="0" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                            <!-- État vide -->
                            <CollectionView.EmptyView>
                                <Border StrokeShape="RoundRectangle 18,18,18,18"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                        Padding="24,30">
                                    <Border.Shadow>
                                        <Shadow Brush="#10000000" Offset="0,2" Radius="8" Opacity="0.3" />
                                    </Border.Shadow>
                                    <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                                        <Label Text="📭" FontSize="40" HorizontalTextAlignment="Center" />
                                        <Label Text="Aucune annonce"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                                        <Label Text="Publiez votre premier objet !"
                                               FontSize="13"
                                               HorizontalTextAlignment="Center"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               Opacity="0.6" />
                                    </VerticalStackLayout>
                                </Border>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- ─── À PROPOS & LÉGAL ─── -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="À propos"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                               Margin="4,0,0,0" />

                        <Border StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                Padding="4,6">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#18000000, Dark=#25000000}" Offset="0,3" Radius="10" Opacity="0.4" />
                            </Border.Shadow>

                            <VerticalStackLayout Spacing="0">
                                <!-- Politique de confidentialité -->
                                <Border StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        Padding="14,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenUrlCommand}"
                                                              CommandParameter="https://bachirtech.github.io/DonTroc/privacy-policy.html" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Label Grid.Column="0" Text="🔒" FontSize="18" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="1"
                                               Text="Politique de confidentialité"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               VerticalTextAlignment="Center" />
                                        <Label Grid.Column="2" Text="›" FontSize="20"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               Opacity="0.4"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Séparateur -->
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{AppThemeBinding Light=#10000000, Dark=#15FFFFFF}"
                                         Margin="14,0" />

                                <!-- Conditions d'utilisation -->
                                <Border StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        Padding="14,14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding OpenUrlCommand}"
                                                              CommandParameter="https://bachirtech.github.io/DonTroc/terms.html" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Label Grid.Column="0" Text="📜" FontSize="18" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="1"
                                               Text="Conditions d'utilisation"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               VerticalTextAlignment="Center" />
                                        <Label Grid.Column="2" Text="›" FontSize="20"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               Opacity="0.4"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Séparateur -->
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{AppThemeBinding Light=#10000000, Dark=#15FFFFFF}"
                                         Margin="14,0" />

                                <!-- Confidentialité publicitaire (RGPD/UMP) — visible uniquement en EEE/UK/CH/BR -->
                                <Border StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        Padding="14,14"
                                        IsVisible="{Binding ShowPrivacyOptionsEntry}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ManagePrivacyConsentCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Label Grid.Column="0" Text="🛡️" FontSize="18" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="1"
                                               Text="Confidentialité publicitaire"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               VerticalTextAlignment="Center" />
                                        <Label Grid.Column="2" Text="›" FontSize="20"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               Opacity="0.4"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Séparateur (visible si le bouton confidentialité l'est) -->
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{AppThemeBinding Light=#10000000, Dark=#15FFFFFF}"
                                         Margin="14,0"
                                         IsVisible="{Binding ShowPrivacyOptionsEntry}" />

                                <!-- 🛠 RESET CONSENT (DEBUG ONLY — visible seulement en mode admin) -->
                                <Border StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        Padding="14,14"
                                        IsVisible="{Binding IsAdmin}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding ResetConsentDebugCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Label Grid.Column="0" Text="🛠" FontSize="18" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="1"
                                               Text="Réinitialiser le consentement (debug)"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               VerticalTextAlignment="Center" />
                                        <Label Grid.Column="2" Text="🔄" FontSize="14"
                                               Opacity="0.5"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Séparateur (visible avec bouton debug) -->
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{AppThemeBinding Light=#10000000, Dark=#15FFFFFF}"
                                         Margin="14,0"
                                         IsVisible="{Binding IsAdmin}" />

                                <!-- Version -->
                                <Border StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        Padding="14,14">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Label Grid.Column="0" Text="ℹ️" FontSize="18" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="1"
                                               Text="Version de l'application"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               VerticalTextAlignment="Center" />
                                        <Label Grid.Column="2"
                                               Text="{Binding AppVersion}"
                                               FontSize="12"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               Opacity="0.6"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>

                                <!-- Séparateur (visible seulement pour admin) -->
                                <BoxView HeightRequest="1"
                                         BackgroundColor="{AppThemeBinding Light=#10000000, Dark=#15FFFFFF}"
                                         Margin="14,0"
                                         IsVisible="{Binding IsAdmin}" />

                                <!-- Config Admin (visible seulement pour admin) -->
                                <Border StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="Transparent"
                                        Padding="14,14"
                                        IsVisible="{Binding IsAdmin}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding NavigateToAdminSetupCommand}" />
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Label Grid.Column="0" Text="⚙️" FontSize="18" VerticalTextAlignment="Center" />
                                        <Label Grid.Column="1"
                                               Text="Configuration admin"
                                               FontSize="14"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               VerticalTextAlignment="Center" />
                                        <Label Grid.Column="2" Text="›" FontSize="20"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               Opacity="0.4"
                                               VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- ─── ZONE DANGER ─── -->
                    <VerticalStackLayout Spacing="10">

                        <!-- Déconnexion -->
                        <Border StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                Padding="0"
                                HeightRequest="52">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                                    <GradientStop Color="{AppThemeBinding Light=#E5A07E, Dark=#C47A58}" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#30D98C6A, Dark=#20000000}" Offset="0,3" Radius="8" Opacity="0.5" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SignOutCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                <Label Text="🚪" FontSize="18" VerticalTextAlignment="Center" />
                                <Label Text="Se déconnecter"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Border>

                        <!-- Supprimer le compte -->
                        <Border StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="2"
                                Stroke="{AppThemeBinding Light=#30E53935, Dark=#40E53935}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                Padding="0"
                                HeightRequest="52">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding DeleteAccountCommand}" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="8">
                                <Label Text="⚠️" FontSize="16" VerticalTextAlignment="Center" />
                                <Label Text="Supprimer mon compte"
                                       FontSize="14"
                                       TextColor="{AppThemeBinding Light={StaticResource Rouge}, Dark={StaticResource RougeSombre}}"
                                       VerticalTextAlignment="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Espacement final -->
                    <BoxView HeightRequest="30" BackgroundColor="Transparent" />

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Overlay pour les conseils -->
        <views:TipOverlayView x:Name="TipOverlay" />
    </Grid>
</ContentPage>

