<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DonTroc.Views.RatingPopupView"
             BackgroundColor="#80000000">
    
    <Grid VerticalOptions="Center" HorizontalOptions="Center" Padding="20">
        <Border BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#2D2D2D}"
                StrokeShape="RoundRectangle 20"
                Stroke="Transparent"
                Padding="25"
                MaximumWidthRequest="350">
            <StackLayout Spacing="20">
                
                <!-- Icône et titre -->
                <StackLayout Spacing="10" HorizontalOptions="Center">
                    <Label Text="⭐" FontSize="60" HorizontalOptions="Center"/>
                    <Label Text="Vous aimez DonTroc ?"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#333333, Dark=#FFFFFF}"/>
                </StackLayout>
                
                <!-- Message -->
                <Label Text="Votre avis compte beaucoup pour moi ! Prenez un instant pour me noter sur le store et m'aider à améliorer l'application. 🙏"
                       FontSize="14"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                       LineHeight="1.3"/>
                
                <!-- Étoiles décoratives -->
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Label Text="⭐" FontSize="30"/>
                    <Label Text="⭐" FontSize="30"/>
                    <Label Text="⭐" FontSize="30"/>
                    <Label Text="⭐" FontSize="30"/>
                    <Label Text="⭐" FontSize="30"/>
                </HorizontalStackLayout>
                
                <!-- Boutons -->
                <StackLayout Spacing="12">
                    
                    <!-- Bouton Noter -->
                    <Button x:Name="RateButton"
                            Text="🌟 Noter l'application"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            FontSize="16"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="25"
                            Clicked="OnRateClicked"/>
                    
                    <!-- Bouton Plus tard -->
                    <Button x:Name="LaterButton"
                            Text="🕐 Plus tard"
                            BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#424242}"
                            TextColor="{AppThemeBinding Light=#666666, Dark=#AAAAAA}"
                            FontSize="14"
                            HeightRequest="45"
                            CornerRadius="22"
                            Clicked="OnLaterClicked"/>
                    
                    <!-- Lien Ne plus demander -->
                    <Label x:Name="DontAskLabel"
                           Text="Ne plus me demander"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#999999, Dark=#777777}"
                           TextDecorations="Underline"
                           HorizontalOptions="Center"
                           Margin="0,5,0,0">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnDontAskClicked"/>
                        </Label.GestureRecognizers>
                    </Label>
                </StackLayout>
                
            </StackLayout>
        </Border>
    </Grid>
    
</ContentView>

