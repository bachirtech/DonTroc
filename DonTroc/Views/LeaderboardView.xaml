<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             xmlns:services="clr-namespace:DonTroc.Services"
             x:DataType="viewModels:LeaderboardViewModel"
             x:Class="DonTroc.Views.LeaderboardView"
             Title="Classement"
             BackgroundColor="{AppThemeBinding Light={StaticResource BeigeClair}, Dark={StaticResource BeigeSombre}}">

    <Grid RowDefinitions="Auto,*">

        <!-- ═══════════════════════════════════════════════ -->
        <!-- HEADER GRADIENT                                 -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,28,28"
                Padding="20,15,20,20">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#8B5A3A}" Offset="0.0" />
                    <GradientStop Color="{AppThemeBinding Light=#C47A58, Dark=#6B4A32}" Offset="0.5" />
                    <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#5A7A3E}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#40000000" Offset="0,6" Radius="16" Opacity="0.3" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="12">
                <!-- Titre -->
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 16,16,16,16"
                            StrokeThickness="0"
                            BackgroundColor="#33FFFFFF"
                            WidthRequest="52" HeightRequest="52"
                            HorizontalOptions="Center" VerticalOptions="Center">
                        <Label Text="🏆" FontSize="26"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                        <Label Text="Classement"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="White"
                               FontFamily="PoppinsBold" />
                        <Label Text="{Binding TotalParticipants, StringFormat='{0} participants'}"
                               FontSize="13"
                               TextColor="#D0FFFFFF" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Onglets Global / Amis -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 12,12,12,12"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="40">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsGlobalSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="#50FFFFFF" />
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsGlobalSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="#20FFFFFF" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Button Text="🌍 Global"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="14"
                                FontAttributes="Bold"
                                CornerRadius="12"
                                Padding="0"
                                Command="{Binding SelectGlobalCommand}" />
                    </Border>
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 12,12,12,12"
                            StrokeThickness="0"
                            Padding="0"
                            HeightRequest="40">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsFriendsSelected}" Value="True">
                                <Setter Property="BackgroundColor" Value="#50FFFFFF" />
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsFriendsSelected}" Value="False">
                                <Setter Property="BackgroundColor" Value="#20FFFFFF" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Button Text="👥 Amis"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                FontSize="14"
                                CornerRadius="12"
                                Padding="0"
                                Command="{Binding SelectFriendsCommand}" />
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- CONTENU                                         -->
        <!-- ═══════════════════════════════════════════════ -->
        <!-- Indicateur de chargement plein écran (premier chargement) -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsBusy}"
                BackgroundColor="{AppThemeBinding Light={StaticResource BeigeClair}, Dark={StaticResource BeigeSombre}}"
                StrokeThickness="0"
                ZIndex="10">
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                <ActivityIndicator IsRunning="True"
                                   Color="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                   HeightRequest="40" WidthRequest="40" />
                <Label Text="Chargement du classement..."
                       FontSize="14"
                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                       Opacity="0.6"
                       HorizontalTextAlignment="Center" />
            </VerticalStackLayout>
        </Border>

        <RefreshView Grid.Row="1" Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
            <ScrollView>
                <VerticalStackLayout Padding="16,0,16,20" Spacing="14" Margin="0,-6,0,0">

                    <!-- ═══════════════════════════════════════ -->
                    <!-- PODIUM TOP 3                            -->
                    <!-- ═══════════════════════════════════════ -->
                    <Border StrokeShape="RoundRectangle 20,20,20,20"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                            Padding="16,20"
                            Margin="0,8,0,0"
                            IsVisible="{Binding HasPodium}">
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#20000000, Dark=#30000000}" Offset="0,4" Radius="14" Opacity="0.4" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" RowDefinitions="Auto,Auto" RowSpacing="8">

                            <!-- 🥈 2ème place (à gauche) -->
                            <VerticalStackLayout Grid.Column="0" Grid.Row="0" Grid.RowSpan="2"
                                                 Spacing="6" HorizontalOptions="Center" VerticalOptions="End"
                                                 IsVisible="{Binding Second, Converter={StaticResource ObjectToBoolConverter}}">
                                <Label Text="🥈" FontSize="28" HorizontalTextAlignment="Center" />
                                <Border StrokeShape="RoundRectangle 25,25,25,25"
                                        StrokeThickness="2"
                                        Stroke="{AppThemeBinding Light=#C0C0C0, Dark=#A0A0A0}"
                                        WidthRequest="50" HeightRequest="50"
                                        BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#333333}"
                                        HorizontalOptions="Center">
                                    <Label Text="{Binding Second.Initials}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding Second.Initials}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                <Label Text="{Binding Second.TotalXp, StringFormat='{0} XP'}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <!-- 🥇 1ère place (au centre, plus grand) -->
                            <VerticalStackLayout Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                                                 Spacing="6" HorizontalOptions="Center" VerticalOptions="Start"
                                                 IsVisible="{Binding First, Converter={StaticResource ObjectToBoolConverter}}">
                                <Label Text="👑" FontSize="22" HorizontalTextAlignment="Center" />
                                <Label Text="🥇" FontSize="34" HorizontalTextAlignment="Center" />
                                <Border StrokeShape="RoundRectangle 32,32,32,32"
                                        StrokeThickness="3"
                                        Stroke="#FFD700"
                                        WidthRequest="64" HeightRequest="64"
                                        BackgroundColor="{AppThemeBinding Light=#FFF8E1, Dark=#3D3520}"
                                        HorizontalOptions="Center">
                                    <Label Text="{Binding First.Initials}"
                                           FontSize="22" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding First.Initials}"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                <Label Text="{Binding First.TotalXp, StringFormat='{0} XP'}"
                                       FontSize="12" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding First.Title}"
                                       FontSize="10"
                                       TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>

                            <!-- 🥉 3ème place (à droite) -->
                            <VerticalStackLayout Grid.Column="2" Grid.Row="0" Grid.RowSpan="2"
                                                 Spacing="6" HorizontalOptions="Center" VerticalOptions="End"
                                                 IsVisible="{Binding Third, Converter={StaticResource ObjectToBoolConverter}}">
                                <Label Text="🥉" FontSize="28" HorizontalTextAlignment="Center" />
                                <Border StrokeShape="RoundRectangle 25,25,25,25"
                                        StrokeThickness="2"
                                        Stroke="{AppThemeBinding Light=#CD7F32, Dark=#A0693A}"
                                        WidthRequest="50" HeightRequest="50"
                                        BackgroundColor="{AppThemeBinding Light=#FFF3E0, Dark=#3D3020}"
                                        HorizontalOptions="Center">
                                    <Label Text="{Binding Third.Initials}"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding Third.Initials}"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                <Label Text="{Binding Third.TotalXp, StringFormat='{0} XP'}"
                                       FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <!-- ═══════════════════════════════════════ -->
                    <!-- VOTRE POSITION                          -->
                    <!-- ═══════════════════════════════════════ -->
                    <Border StrokeShape="RoundRectangle 16,16,16,16"
                            StrokeThickness="2"
                            Stroke="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}"
                            Padding="14,12"
                            IsVisible="{Binding HasCurrentUser}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{AppThemeBinding Light=#FFF5EE, Dark=#3D2E24}" Offset="0.0" />
                                <GradientStop Color="{AppThemeBinding Light=#FFEDE3, Dark=#4D3E34}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#30D98C6A, Dark=#20000000}" Offset="0,3" Radius="10" Opacity="0.4" />
                        </Border.Shadow>

                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="12">
                            <!-- Rang -->
                            <Label Grid.Column="0"
                                   Text="{Binding CurrentUserEntry.RankDisplay}"
                                   FontSize="20" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                   VerticalTextAlignment="Center" />

                            <!-- Avatar -->
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 14,14,14,14"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#FFEDE3, Dark=#4D3E34}"
                                    WidthRequest="42" HeightRequest="42"
                                    VerticalOptions="Center">
                                <Label Text="👤" FontSize="20"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>

                            <!-- Infos -->
                            <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                <Label Text="Vous"
                                       FontSize="15" FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                                <Label FontSize="11"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       Opacity="0.7">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Niv. " />
                                            <Span Text="{Binding CurrentUserEntry.Level}" FontAttributes="Bold" />
                                            <Span Text=" · " />
                                            <Span Text="{Binding CurrentUserEntry.Title}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>

                            <!-- XP -->
                            <Border Grid.Column="3"
                                    StrokeShape="RoundRectangle 10,10,10,10"
                                    StrokeThickness="0"
                                    Padding="10,6"
                                    VerticalOptions="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#E5A07E, Dark=#C47A58}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Label TextColor="White" FontSize="12" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="✨ " />
                                            <Span Text="{Binding CurrentUserEntry.TotalXp}" />
                                            <Span Text=" XP" FontSize="9" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ═══════════════════════════════════════ -->
                    <!-- LISTE DES AUTRES CLASSÉS               -->
                    <!-- ═══════════════════════════════════════ -->
                    <Label Text="Classement complet"
                           FontSize="16" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                           Margin="4,4,0,0"
                           IsVisible="{Binding IsEmpty, Converter={StaticResource InverseBoolConverter}}" />

                    <VerticalStackLayout Spacing="8"
                                         BindableLayout.ItemsSource="{Binding LeaderboardEntries}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="services:LeaderboardEntry">
                                <Border StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                                        Padding="12,10">
                                    <Border.Shadow>
                                        <Shadow Brush="{AppThemeBinding Light=#10000000, Dark=#15000000}" Offset="0,2" Radius="8" Opacity="0.3" />
                                    </Border.Shadow>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsCurrentUser}" Value="True">
                                            <Setter Property="StrokeThickness" Value="2" />
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" />
                                        </DataTrigger>
                                    </Border.Triggers>

                                    <Grid ColumnDefinitions="40,Auto,*,Auto" ColumnSpacing="10">
                                        <!-- Rang -->
                                        <Label Grid.Column="0"
                                               Text="{Binding RankDisplay}"
                                               FontSize="15" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center" />

                                        <!-- Avatar initiales -->
                                        <Border Grid.Column="1"
                                                StrokeShape="RoundRectangle 12,12,12,12"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}"
                                                WidthRequest="40" HeightRequest="40"
                                                VerticalOptions="Center">
                                            <Label Text="{Binding Initials}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>

                                        <!-- Nom + Niveau -->
                                        <VerticalStackLayout Grid.Column="2" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding Initials}"
                                                   FontSize="14" FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                                   LineBreakMode="TailTruncation" MaxLines="1" />
                                            <Label FontSize="11"
                                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                                   Opacity="0.6">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="Niv. " />
                                                        <Span Text="{Binding Level}" FontAttributes="Bold" />
                                                        <Span Text=" · " />
                                                        <Span Text="{Binding Title}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </VerticalStackLayout>

                                        <!-- XP -->
                                        <Label Grid.Column="3"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}"
                                               VerticalTextAlignment="Center">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding TotalXp}" />
                                                    <Span Text=" XP" FontSize="10" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <!-- État vide -->
                    <Border StrokeShape="RoundRectangle 18,18,18,18"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                            Padding="28,36"
                            Margin="0,20"
                            IsVisible="{Binding IsEmpty}">
                        <VerticalStackLayout HorizontalOptions="Center" Spacing="12">
                            <Label Text="🏆" FontSize="48" HorizontalTextAlignment="Center" />
                            <Label Text="Pas encore de classement"
                                   FontSize="17" FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                            <Label Text="Gagnez des XP pour apparaître dans le classement !"
                                   FontSize="13"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                   Opacity="0.6" />
                        </VerticalStackLayout>
                    </Border>

                    <BoxView HeightRequest="10" BackgroundColor="Transparent" />
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>

