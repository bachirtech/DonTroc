<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             x:DataType="viewModels:OnboardingViewModel"
             x:Class="DonTroc.Views.OnboardingView"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource BeigeClair}, Dark={StaticResource BeigeSombre}}">

    <Grid RowDefinitions="*,Auto,Auto" Padding="0">

        <!-- ═══════════════════════════════════════════════ -->
        <!-- CAROUSEL DES SLIDES                             -->
        <!-- ═══════════════════════════════════════════════ -->
        <CarouselView Grid.Row="0"
                      x:Name="OnboardingCarousel"
                      ItemsSource="{Binding Slides}"
                      Position="{Binding CurrentPosition, Mode=TwoWay}"
                      Loop="False"
                      IndicatorView="SlideIndicator"
                      HorizontalScrollBarVisibility="Never">
            <CarouselView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:OnboardingSlide">
                    <Grid Padding="32,40,32,20" VerticalOptions="Center">
                        <VerticalStackLayout Spacing="24" VerticalOptions="Center" HorizontalOptions="Center">

                            <!-- Emoji géant -->
                            <Border StrokeShape="RoundRectangle 40,40,40,40"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#FFF5EE, Dark=#3D2E24}"
                                    WidthRequest="120" HeightRequest="120"
                                    HorizontalOptions="Center">
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#30D98C6A, Dark=#20000000}"
                                           Offset="0,6" Radius="20" Opacity="0.4" />
                                </Border.Shadow>
                                <Label Text="{Binding Emoji}"
                                       FontSize="52"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>

                            <!-- Titre -->
                            <Label Text="{Binding Title}"
                                   FontSize="26"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                   HorizontalTextAlignment="Center"
                                   FontFamily="PoppinsBold" />

                            <!-- Description -->
                            <Label Text="{Binding Description}"
                                   FontSize="15"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                   Opacity="0.75"
                                   HorizontalTextAlignment="Center"
                                   LineHeight="1.4"
                                   MaxLines="8" />

                            <!-- Bouton notifications (slide 4 uniquement) -->
                            <Border StrokeShape="RoundRectangle 16,16,16,16"
                                    StrokeThickness="0"
                                    Padding="20,14"
                                    HorizontalOptions="Center"
                                    IsVisible="{Binding ShowNotificationButton}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#5A7A3E}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#8FB86E, Dark=#4A6A2E}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#30A8C686, Dark=#20000000}"
                                           Offset="0,4" Radius="12" Opacity="0.5" />
                                </Border.Shadow>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:OnboardingViewModel}}, Path=RequestNotificationsCommand}" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                    <Label Text="🔔" FontSize="18" VerticalOptions="Center" />
                                    <Label Text="Activer les notifications"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="White"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </CarouselView.ItemTemplate>
        </CarouselView>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- INDICATEUR DE PROGRESSION (DOTS)                -->
        <!-- ═══════════════════════════════════════════════ -->
        <IndicatorView Grid.Row="1"
                       x:Name="SlideIndicator"
                       IndicatorColor="{AppThemeBinding Light=#D0D0D0, Dark=#555555}"
                       SelectedIndicatorColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                       IndicatorSize="10"
                       HorizontalOptions="Center"
                       Margin="0,0,0,10" />

        <!-- ═══════════════════════════════════════════════ -->
        <!-- BOUTONS D'ACTION                                -->
        <!-- ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Padding="24,10,24,36" ColumnSpacing="16">

            <!-- Passer (visible sauf dernier slide) -->
            <Label Grid.Column="0"
                   Text="Passer"
                   FontSize="15"
                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                   Opacity="0.5"
                   VerticalOptions="Center"
                   TextDecorations="Underline">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SkipCommand}" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Bouton Suivant / C'est parti -->
            <Border Grid.Column="1"
                    StrokeShape="RoundRectangle 16,16,16,16"
                    StrokeThickness="0"
                    Padding="0"
                    HeightRequest="52"
                    HorizontalOptions="Fill">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#C47A58, Dark=#A06040}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#40D98C6A, Dark=#30000000}"
                           Offset="0,4" Radius="14" Opacity="0.5" />
                </Border.Shadow>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NextCommand}" />
                </Border.GestureRecognizers>
                <Label Text="{Binding ButtonText}"
                       FontSize="17"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Border>
        </Grid>

    </Grid>

</ContentPage>

