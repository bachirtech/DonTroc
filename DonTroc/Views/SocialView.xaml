<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             xmlns:models="clr-namespace:DonTroc.Models"
             x:DataType="viewModels:SocialViewModel"
             x:Class="DonTroc.Views.SocialView"
             Title="Social">

    <Grid RowDefinitions="Auto,*" Padding="15" RowSpacing="15">
        
        <!-- En-tête avec statistiques -->
        <Border Grid.Row="0" 
                StrokeShape="RoundRectangle 18,18,18,18"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                Padding="20">
            <Border.Shadow>
                <Shadow Brush="{AppThemeBinding Light=#20A8C686, Dark=#30000000}" Offset="0,4" Radius="14" Opacity="0.4" />
            </Border.Shadow>
            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="15">
                
                <!-- Titre -->
                <Label Grid.Row="0" Text="🌟 Votre Impact Social" 
                       FontSize="Large" FontAttributes="Bold" 
                       HorizontalOptions="Center" 
                       TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}" />
                
                <!-- Statistiques en grille -->
                <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="10">
                    
                    <!-- Amis -->
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 16,16,16,16"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#F0FFFFFF, Dark=#30FFFFFF}"
                            Padding="14,16">
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#25A8C686, Dark=#20000000}" Offset="0,3" Radius="10" Opacity="0.4" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 14,14,14,14"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#E8F5E0, Dark=#2A3D22}"
                                    WidthRequest="42" HeightRequest="42"
                                    HorizontalOptions="Center">
                                <Label Text="👥" FontSize="20"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="{Binding SocialStats.NombreAmis}" 
                                   FontSize="28" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}" 
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Amis" FontSize="11" 
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" 
                                   HorizontalTextAlignment="Center" Opacity="0.8" />
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Parrainages -->
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 16,16,16,16"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#F0FFFFFF, Dark=#30FFFFFF}"
                            Padding="14,16">
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#25D98C6A, Dark=#20000000}" Offset="0,3" Radius="10" Opacity="0.4" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 14,14,14,14"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#FFEDE3, Dark=#3D2E24}"
                                    WidthRequest="42" HeightRequest="42"
                                    HorizontalOptions="Center">
                                <Label Text="🎯" FontSize="20"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="{Binding SocialStats.NombreParrainages}" 
                                   FontSize="28" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" 
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Parrainages" FontSize="10" 
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" 
                                   HorizontalTextAlignment="Center" Opacity="0.8" />
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Partages -->
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 16,16,16,16"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#F0FFFFFF, Dark=#30FFFFFF}"
                            Padding="14,16">
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#256B7A8F, Dark=#20000000}" Offset="0,3" Radius="10" Opacity="0.4" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 14,14,14,14"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#E8EDF2, Dark=#2A3040}"
                                    WidthRequest="42" HeightRequest="42"
                                    HorizontalOptions="Center">
                                <Label Text="📤" FontSize="20"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <Label Text="{Binding SocialStats.NombrePartages}" 
                                   FontSize="28" FontAttributes="Bold" 
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" 
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Partages" FontSize="11" 
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" 
                                   HorizontalTextAlignment="Center" Opacity="0.8" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
                
                <!-- Boutons d'action -->
                <Grid Grid.Row="2" ColumnDefinitions="*,*" ColumnSpacing="10">
                    <Button Grid.Column="0" Text="🎁 Mon Code" 
                            BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocPrimary}, Dark={StaticResource DonTrocPrimaryDark}}"
                            TextColor="White"
                            FontFamily="PoppinsBold" FontSize="14"
                            CornerRadius="22" Padding="14,10"
                            Command="{Binding GenerateReferralCodeCommand}" />
                    <Button Grid.Column="1" Text="🔗 Utiliser Code" 
                            BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocSecondary}, Dark={StaticResource DonTrocSecondaryDark}}"
                            TextColor="White"
                            FontFamily="PoppinsBold" FontSize="14"
                            CornerRadius="22" Padding="14,10"
                            Clicked="OnUseReferralCodeClicked" />
                </Grid>
            </Grid>
        </Border>
        
        <!-- Contenu principal avec tabs -->
        <Grid Grid.Row="1">
            
            <!-- Activité des amis -->
            <ScrollView>
                <StackLayout Spacing="15">
                    
                    <!-- Section Mes Amis -->
                    <Frame Style="{StaticResource CardFrame}" Padding="15">
                        <StackLayout Spacing="10">
                            <Label Text="👥 Mes Amis" FontSize="Medium" FontAttributes="Bold" 
                                   TextColor="{StaticResource VertSauge}" />
                            
                            <CollectionView ItemsSource="{Binding Friends}" 
                                          HeightRequest="120">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="10" />
                                </CollectionView.ItemsLayout>
                                
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:UserProfile">
                                        <StackLayout WidthRequest="80" Spacing="5">
                                            <Frame WidthRequest="60" HeightRequest="60" 
                                                   CornerRadius="30" Padding="0" 
                                                   BackgroundColor="LightGray"
                                                   HorizontalOptions="Center">
                                                <Image Source="{Binding PhotoProfil}" 
                                                       Aspect="AspectFill" />
                                            </Frame>
                                            <Label Text="{Binding Nom}" FontSize="Micro" 
                                                   HorizontalOptions="Center" 
                                                   LineBreakMode="TailTruncation" />
                                        </StackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                                
                                <CollectionView.EmptyView>
                                    <StackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                        <Label Text="🔗 Aucun ami pour le moment" 
                                               FontSize="Small" TextColor="{StaticResource Ardoise}" 
                                               HorizontalOptions="Center" />
                                        <Label Text="Utilisez un code de parrainage pour ajouter des amis !" 
                                               FontSize="Micro" TextColor="{StaticResource Ardoise}" 
                                               HorizontalOptions="Center" />
                                    </StackLayout>
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </StackLayout>
                    </Frame>
                    
                    <!-- Section Activité récente -->
                    <Frame Style="{StaticResource CardFrame}" Padding="15">
                        <StackLayout Spacing="10">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="📈 Activité des Amis" 
                                       FontSize="Medium" FontAttributes="Bold" 
                                       TextColor="{StaticResource VertSauge}" />
                                <Button Grid.Column="1" Text="🔄" 
                                        Style="{StaticResource SecondaryButton}"
                                        WidthRequest="40" HeightRequest="40"
                                        Command="{Binding RefreshActivityCommand}" />
                            </Grid>
                            
                            <CollectionView ItemsSource="{Binding FriendsActivity}"
                                          HeightRequest="300">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:FriendActivity">
                                        <Frame Style="{StaticResource CardFrame}" 
                                               Margin="0,5" Padding="12">
                                            <Grid ColumnDefinitions="50,*,Auto" ColumnSpacing="10">
                                                
                                                <!-- Photo de l'ami -->
                                                <Frame Grid.Column="0" WidthRequest="40" HeightRequest="40" 
                                                       CornerRadius="20" Padding="0" 
                                                       BackgroundColor="LightGray">
                                                    <Image Source="{Binding UserPhotoUrl}" 
                                                           Aspect="AspectFill" />
                                                </Frame>
                                                
                                                <!-- Contenu -->
                                                <StackLayout Grid.Column="1" Spacing="2">
                                                    <Label Text="{Binding UserName}" 
                                                           FontAttributes="Bold" FontSize="Small" />
                                                    <Label Text="{Binding Description}" 
                                                           FontSize="Micro" TextColor="{StaticResource Ardoise}"
                                                           LineBreakMode="TailTruncation" MaxLines="2" />
                                                    <Label Text="{Binding DateActivite, StringFormat='{0:dd/MM HH:mm}'}" 
                                                           FontSize="Micro" TextColor="{StaticResource Terracotta}" />
                                                </StackLayout>
                                                
                                                <!-- Points -->
                                                <Frame Grid.Column="2" BackgroundColor="{StaticResource VertSauge}"
                                                       Padding="8,4" CornerRadius="12" 
                                                       IsVisible="{Binding Points, Converter={StaticResource IntToBoolConverter}}">
                                                    <Label Text="{Binding Points, StringFormat='+{0} pts'}" 
                                                           TextColor="White" FontSize="Micro" />
                                                </Frame>
                                            </Grid>
                                        </Frame>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                                
                                <CollectionView.EmptyView>
                                    <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Padding="20">
                                        <Label Text="📱 Aucune activité récente" 
                                               FontSize="Small" TextColor="{StaticResource Ardoise}" 
                                               HorizontalOptions="Center" />
                                        <Label Text="L'activité de vos amis apparaîtra ici" 
                                               FontSize="Micro" TextColor="{StaticResource Ardoise}" 
                                               HorizontalOptions="Center" />
                                    </StackLayout>
                                </CollectionView.EmptyView>
                            </CollectionView>
                        </StackLayout>
                    </Frame>
                </StackLayout>
            </ScrollView>
        </Grid>
        
        <!-- Dialog pour utiliser un code de parrainage -->
        <Frame Grid.RowSpan="2" 
               BackgroundColor="#80000000" 
               IsVisible="{Binding ShowReferralDialog}"
               Padding="20" 
               VerticalOptions="Center">
            <Frame Style="{StaticResource CardFrame}" Padding="25">
                <StackLayout Spacing="20">
                    <Label Text="🎁 Utiliser un Code de Parrainage" 
                           FontSize="Large" FontAttributes="Bold" 
                           HorizontalOptions="Center"
                           TextColor="{StaticResource VertSauge}" />
                    
                    <Label Text="Saisissez le code de parrainage d'un ami pour devenir amis et gagner des points !" 
                           FontSize="Small" TextColor="{StaticResource Ardoise}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    
                    <Border Style="{StaticResource InputContainer}">
                        <Entry Placeholder="Ex: ABC123" 
                               Text="{Binding ReferralCodeToUse}"
                               FontSize="Large" 
                               HorizontalTextAlignment="Center"
                               TextTransform="Uppercase" />
                    </Border>
                    
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Grid.Column="0" Text="Annuler" 
                                Style="{StaticResource SecondaryButton}"
                                Clicked="OnCancelReferralDialog" />
                        <Button Grid.Column="1" Text="Utiliser" 
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding UseReferralCodeCommand}"
                                CommandParameter="{Binding ReferralCodeToUse}" />
                    </Grid>
                </StackLayout>
            </Frame>
        </Frame>
        
        <!-- Dialog pour partager une annonce -->
        <Frame Grid.RowSpan="2" 
               BackgroundColor="#80000000" 
               IsVisible="{Binding ShowShareDialog}"
               Padding="20" 
               VerticalOptions="Center">
            <Frame Style="{StaticResource CardFrame}" Padding="25">
                <StackLayout Spacing="20">
                    <Label Text="📤 Partager cette annonce" 
                           FontSize="Large" FontAttributes="Bold" 
                           HorizontalOptions="Center"
                           TextColor="{StaticResource VertSauge}" />
                    
                    <Label Text="{Binding AnnonceToShare.Titre}" 
                           FontSize="Medium" FontAttributes="Bold"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    
                    <Label Text="Choisissez où partager cette bonne action :" 
                           FontSize="Small" TextColor="{StaticResource Ardoise}"
                           HorizontalOptions="Center" />
                    
                    <!-- Boutons de partage en grille -->
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" 
                          ColumnSpacing="10" RowSpacing="10">
                        
                        <Button Grid.Row="0" Grid.Column="0" Text="📱 WhatsApp" 
                                Style="{StaticResource SecondaryButton}" FontSize="Small"
                                Clicked="OnShareWhatsApp" />
                        <Button Grid.Row="0" Grid.Column="1" Text="✈️ Telegram" 
                                Style="{StaticResource SecondaryButton}" FontSize="Small"
                                Clicked="OnShareTelegram" />
                        <Button Grid.Row="0" Grid.Column="2" Text="📘 Facebook" 
                                Style="{StaticResource SecondaryButton}" FontSize="Small"
                                Clicked="OnShareFacebook" />
                        
                        <Button Grid.Row="1" Grid.Column="0" Text="🐦 Twitter" 
                                Style="{StaticResource SecondaryButton}" FontSize="Small"
                                Clicked="OnShareTwitter" />
                        <Button Grid.Row="1" Grid.Column="1" Text="📧 Email" 
                                Style="{StaticResource SecondaryButton}" FontSize="Small"
                                Clicked="OnShareEmail" />
                        <Button Grid.Row="1" Grid.Column="2" Text="💬 SMS" 
                                Style="{StaticResource SecondaryButton}" FontSize="Small"
                                Clicked="OnShareSMS" />
                        
                        <Button Grid.Row="2" Grid.ColumnSpan="3" Text="Annuler" 
                                Style="{StaticResource PrimaryButton}"
                                Clicked="OnCancelShareDialog" />
                    </Grid>
                </StackLayout>
            </Frame>
        </Frame>
        
        <!-- Dialog pour afficher le code de parrainage -->
        <Frame Grid.RowSpan="2" 
               BackgroundColor="#80000000" 
               IsVisible="{Binding UserReferralCode, Converter={StaticResource ObjectToBoolConverter}}"
               Padding="20" 
               VerticalOptions="Center">
            <Frame Style="{StaticResource CardFrame}" Padding="25"
                   IsVisible="{Binding UserReferralCode, Converter={StaticResource ObjectToBoolConverter}}">
                <StackLayout Spacing="20">
                    <Label Text="🎯 Votre Code de Parrainage" 
                           FontSize="Large" FontAttributes="Bold" 
                           HorizontalOptions="Center"
                           TextColor="{StaticResource VertSauge}" />
                    
                    <Frame BackgroundColor="{StaticResource VertSauge}" 
                           Padding="20" CornerRadius="15">
                        <Label Text="{Binding UserReferralCode.Code}" 
                               FontSize="Title" FontAttributes="Bold"
                               TextColor="White" 
                               HorizontalOptions="Center" 
                               HorizontalTextAlignment="Center" />
                    </Frame>
                    
                    <Label Text="Partagez ce code avec vos amis pour qu'ils vous rejoignent sur DonTroc !" 
                           FontSize="Small" TextColor="{StaticResource Ardoise}"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                    
                    <StackLayout Spacing="5">
                        <Label Text="{Binding UserReferralCode.NbUtilisations, StringFormat='✅ {0} utilisations'}" 
                               FontSize="Small" HorizontalOptions="Center" />
                        <Label Text="{Binding UserReferralCode.MaxUtilisations, StringFormat='📊 Maximum : {0} utilisations'}" 
                               FontSize="Micro" TextColor="{StaticResource Ardoise}"
                               HorizontalOptions="Center" />
                    </StackLayout>
                    
                    <Button Text="Fermer" 
                            Style="{StaticResource PrimaryButton}"
                            Clicked="OnCloseReferralCodeDialog" />
                </StackLayout>
            </Frame>
        </Frame>
    </Grid>
</ContentPage>
