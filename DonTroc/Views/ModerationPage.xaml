<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             xmlns:models="clr-namespace:DonTroc.Models"
             x:Class="DonTroc.Views.ModerationPage"
             x:DataType="viewModels:ModerationViewModel"
             Title="Modération"
             BackgroundColor="{StaticResource GrisClair}">
    
    <Grid RowDefinitions="Auto,Auto,*,Auto">
        
        <!-- En-tête avec stats -->
        <Frame Grid.Row="0" 
               BackgroundColor="{StaticResource Terracotta}" 
               Padding="15" 
               CornerRadius="0"
               HasShadow="True">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="🚨 Signalements"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"/>
                    <Label TextColor="White" Opacity="0.9">
                        <Label.FormattedText>
                            <FormattedString>
                                <Span Text="{Binding PendingCount}" FontAttributes="Bold"/>
                                <Span Text=" en attente sur "/>
                                <Span Text="{Binding TotalCount}"/>
                            </FormattedString>
                        </Label.FormattedText>
                    </Label>
                </VerticalStackLayout>
                
                <HorizontalStackLayout Grid.Column="1" Spacing="10" VerticalOptions="Center">
                    <Button Text="{Binding IsSelectionMode, Converter={StaticResource BoolToSelectionModeTextConverter}}"
                            Command="{Binding ToggleSelectionModeCommand}"
                            BackgroundColor="White"
                            TextColor="{StaticResource Terracotta}"
                            CornerRadius="15"
                            Padding="10,5"
                            FontSize="12"/>
                    
                    <Button Text="🔄"
                            Command="{Binding LoadReportsCommand}"
                            BackgroundColor="White"
                            TextColor="{StaticResource Terracotta}"
                            CornerRadius="20"
                            WidthRequest="40"
                            HeightRequest="40"
                            Padding="0"/>
                </HorizontalStackLayout>
            </Grid>
        </Frame>
        
        <!-- Filtres -->
        <Frame Grid.Row="1" 
               BackgroundColor="White" 
               Padding="10" 
               CornerRadius="0"
               HasShadow="True">
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Picker Grid.Column="0"
                        Title="Statut"
                        ItemsSource="{Binding StatusFilters}"
                        SelectedItem="{Binding SelectedStatusFilter}"
                        BackgroundColor="{StaticResource GrisClair}"/>
                
                <Picker Grid.Column="1"
                        Title="Type"
                        ItemsSource="{Binding TypeFilters}"
                        SelectedItem="{Binding SelectedTypeFilter}"
                        BackgroundColor="{StaticResource GrisClair}"/>
            </Grid>
        </Frame>
        
        <!-- Indicateur de chargement -->
        <ActivityIndicator Grid.Row="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           Color="{StaticResource Terracotta}"
                           VerticalOptions="Center"
                           HeightRequest="40"/>
        
        <!-- Liste des signalements -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding FilteredReports}"
                        SelectionMode="None"
                        EmptyView="🎉 Aucun signalement à traiter !">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Report">
                    <SwipeView>
                        <SwipeView.LeftItems>
                            <SwipeItems>
                                <SwipeItem Text="Détails"
                                           BackgroundColor="{StaticResource Primaire}"
                                           Invoked="OnDetailsSwiped"/>
                            </SwipeItems>
                        </SwipeView.LeftItems>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Résoudre"
                                           BackgroundColor="#27AE60"
                                           Invoked="OnResolveSwiped"/>
                                <SwipeItem Text="Suspendre"
                                           BackgroundColor="#E74C3C"
                                           Invoked="OnSuspendSwiped"/>
                            </SwipeItems>
                        </SwipeView.RightItems>
                        
                        <Frame Margin="10,5" 
                               Padding="15" 
                               CornerRadius="10"
                               BackgroundColor="White"
                               HasShadow="True">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnReportTapped"/>
                            </Frame.GestureRecognizers>
                            
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="15">
                                <!-- Icône statut -->
                                <Frame Grid.Column="0"
                                       WidthRequest="40"
                                       HeightRequest="40"
                                       CornerRadius="20"
                                       Padding="0"
                                       HasShadow="False"
                                       VerticalOptions="Start">
                                    <Frame.Triggers>
                                        <DataTrigger TargetType="Frame" 
                                                     Binding="{Binding Status}" 
                                                     Value="Pending">
                                            <Setter Property="BackgroundColor" Value="#FFF3E0"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Frame" 
                                                     Binding="{Binding Status}" 
                                                     Value="Reviewed">
                                            <Setter Property="BackgroundColor" Value="#E3F2FD"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Frame" 
                                                     Binding="{Binding Status}" 
                                                     Value="ActionTaken">
                                            <Setter Property="BackgroundColor" Value="#E8F5E9"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Frame" 
                                                     Binding="{Binding Status}" 
                                                     Value="Dismissed">
                                            <Setter Property="BackgroundColor" Value="#FFEBEE"/>
                                        </DataTrigger>
                                    </Frame.Triggers>
                                    <Label FontSize="20" 
                                           HorizontalOptions="Center" 
                                           VerticalOptions="Center">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" 
                                                         Binding="{Binding Status}" 
                                                         Value="Pending">
                                                <Setter Property="Text" Value="⏳"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" 
                                                         Binding="{Binding Status}" 
                                                         Value="Reviewed">
                                                <Setter Property="Text" Value="👁️"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" 
                                                         Binding="{Binding Status}" 
                                                         Value="ActionTaken">
                                                <Setter Property="Text" Value="✅"/>
                                            </DataTrigger>
                                            <DataTrigger TargetType="Label" 
                                                         Binding="{Binding Status}" 
                                                         Value="Dismissed">
                                                <Setter Property="Text" Value="❌"/>
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Frame>
                                
                                <!-- Contenu -->
                                <VerticalStackLayout Grid.Column="1" Spacing="5">
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding ReportedItemType}" 
                                               FontSize="14"
                                               FontAttributes="Bold"/>
                                        <Frame Padding="5,2"
                                               CornerRadius="8"
                                               HasShadow="False">
                                            <Frame.Triggers>
                                                <DataTrigger TargetType="Frame" 
                                                             Binding="{Binding Status}" 
                                                             Value="Pending">
                                                    <Setter Property="BackgroundColor" Value="#FF9800"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" 
                                                             Binding="{Binding Status}" 
                                                             Value="Reviewed">
                                                    <Setter Property="BackgroundColor" Value="#2196F3"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" 
                                                             Binding="{Binding Status}" 
                                                             Value="ActionTaken">
                                                    <Setter Property="BackgroundColor" Value="#4CAF50"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Frame" 
                                                             Binding="{Binding Status}" 
                                                             Value="Dismissed">
                                                    <Setter Property="BackgroundColor" Value="#F44336"/>
                                                </DataTrigger>
                                            </Frame.Triggers>
                                            <Label Text="{Binding Status}"
                                                   FontSize="10"
                                                   TextColor="White"/>
                                        </Frame>
                                    </HorizontalStackLayout>
                                    
                                    <Label Text="{Binding Reason}"
                                           FontSize="13"
                                           TextColor="{StaticResource Ardoise}"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="2"/>
                                    
                                    <Label Text="{Binding Timestamp, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                           FontSize="11"
                                           TextColor="{StaticResource GrisClair}"/>
                                </VerticalStackLayout>
                                
                                <!-- Bouton action rapide -->
                                <Button Grid.Column="2"
                                        Text="⚡"
                                        Clicked="OnQuickActionClicked"
                                        BackgroundColor="{StaticResource Primaire}"
                                        TextColor="White"
                                        CornerRadius="20"
                                        WidthRequest="40"
                                        HeightRequest="40"
                                        Padding="0"
                                        VerticalOptions="Center"/>
                            </Grid>
                        </Frame>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        
        <!-- Barre d'actions en masse -->
        <Frame Grid.Row="3"
               BackgroundColor="{StaticResource Primaire}"
               Padding="15"
               CornerRadius="0"
               HasShadow="True"
               IsVisible="{Binding IsSelectionMode}">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       TextColor="White"
                       VerticalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="{Binding SelectedReports.Count}"/>
                            <Span Text=" sélectionné(s)"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                
                <Button Grid.Column="1"
                        Text="Traiter"
                        Command="{Binding BulkUpdateStatusCommand}"
                        BackgroundColor="White"
                        TextColor="{StaticResource Primaire}"
                        CornerRadius="15"
                        Padding="20,10"/>
            </Grid>
        </Frame>
    </Grid>
    
</ContentPage>
