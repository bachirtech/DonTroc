<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             xmlns:models="clr-namespace:DonTroc.Models"
             x:DataType="viewModels:TradeProposalsListViewModel"
             x:Class="DonTroc.Views.TradeProposalsListPage"
             Title="Mes propositions de troc"
             BackgroundColor="{AppThemeBinding Light={StaticResource BeigeClair}, Dark={StaticResource BeigeSombre}}">

    <ContentPage.Resources>
        <DataTemplate x:Key="ProposalTemplate" x:DataType="models:TradeProposal">
            <Border StrokeShape="RoundRectangle 16,16,16,16"
                    StrokeThickness="0"
                    Margin="16,6"
                    Padding="14"
                    BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}">
                <Border.Shadow>
                    <Shadow Brush="#15000000" Offset="0,3" Radius="10" Opacity="0.3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">

                    <!-- En-tête : statut + date -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0" Text="{Binding StatutDisplay}"
                               FontSize="12" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />
                        <Label Grid.Column="1" Text="{Binding DateCreationFormatted}"
                               FontSize="11" Opacity="0.6"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                    </Grid>

                    <!-- Échange visuel -->
                    <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 10,10,10,10"
                                    StrokeThickness="0"
                                    WidthRequest="64" HeightRequest="64"
                                    BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}">
                                <Image Source="{Binding OfferedAnnoncePhoto}" Aspect="AspectFill" />
                            </Border>
                            <Label Text="{Binding OfferedAnnonceTitre}"
                                   FontSize="11"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                        </VerticalStackLayout>

                        <Label Grid.Column="1" Text="↔" FontSize="22"
                               VerticalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />

                        <VerticalStackLayout Grid.Column="2" Spacing="4" HorizontalOptions="Center">
                            <Border StrokeShape="RoundRectangle 10,10,10,10"
                                    StrokeThickness="0"
                                    WidthRequest="64" HeightRequest="64"
                                    BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}">
                                <Image Source="{Binding AnnonceCiblePhoto}" Aspect="AspectFill" />
                            </Border>
                            <Label Text="{Binding AnnonceCibleTitre}"
                                   FontSize="11"
                                   MaxLines="2"
                                   LineBreakMode="TailTruncation"
                                   HorizontalTextAlignment="Center"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Proposeur (visible uniquement pour les reçues) -->
                    <HorizontalStackLayout Spacing="6"
                                           IsVisible="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TradeProposalsListViewModel}}, Path=IsReceivedTab}">
                        <Label Text="👤" FontSize="13" VerticalTextAlignment="Center" />
                        <Label Text="{Binding ProposerName}"
                               FontSize="12"
                               FontAttributes="Bold"
                               VerticalTextAlignment="Center"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                    </HorizontalStackLayout>

                    <!-- Message -->
                    <Label Text="{Binding Message}"
                           FontSize="13"
                           Opacity="0.85"
                           LineBreakMode="WordWrap"
                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                           IsVisible="{Binding Message, Converter={StaticResource StringNotNullOrEmptyConverter}}" />

                    <!-- Actions (reçues, en attente uniquement) -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="8"
                          IsVisible="{Binding IsPending}">
                        <!-- Refuser -->
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 12,12,12,12"
                                StrokeThickness="0"
                                HeightRequest="42"
                                BackgroundColor="{AppThemeBinding Light=#FFF0F0, Dark=#3D2424}"
                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TradeProposalsListViewModel}}, Path=IsReceivedTab}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TradeProposalsListViewModel}}, Path=DeclineCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="❌ Refuser"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   TextColor="{StaticResource Rouge}" />
                        </Border>

                        <!-- Accepter -->
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 12,12,12,12"
                                StrokeThickness="0"
                                HeightRequest="42"
                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TradeProposalsListViewModel}}, Path=IsReceivedTab}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#8AA868}" Offset="0.0" />
                                    <GradientStop Color="{AppThemeBinding Light=#8AA868, Dark=#6E8A50}" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TradeProposalsListViewModel}}, Path=AcceptCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="✅ Accepter"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   TextColor="White" />
                        </Border>

                        <!-- Annuler (onglet Envoyées) -->
                        <Border Grid.ColumnSpan="2"
                                StrokeShape="RoundRectangle 12,12,12,12"
                                StrokeThickness="0"
                                HeightRequest="42"
                                BackgroundColor="{AppThemeBinding Light=#FFF0F0, Dark=#3D2424}"
                                IsVisible="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TradeProposalsListViewModel}}, Path=IsSentTab}">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:TradeProposalsListViewModel}}, Path=CancelCommand}"
                                    CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Label Text="🚫 Annuler ma proposition"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   VerticalTextAlignment="Center"
                                   TextColor="{StaticResource Rouge}" />
                        </Border>
                    </Grid>

                </VerticalStackLayout>
            </Border>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Onglets -->
        <Grid Grid.Row="0" ColumnDefinitions="*,*" Padding="16,12,16,6">
            <Border Grid.Column="0"
                    StrokeShape="RoundRectangle 12,12,12,12"
                    StrokeThickness="0"
                    HeightRequest="42"
                    Margin="0,0,4,0"
                    BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsReceivedTab}" Value="True">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="received" />
                </Border.GestureRecognizers>
                <Label Text="📥 Reçues"
                       FontSize="14"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsReceivedTab}" Value="True">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>

            <Border Grid.Column="1"
                    StrokeShape="RoundRectangle 12,12,12,12"
                    StrokeThickness="0"
                    HeightRequest="42"
                    Margin="4,0,0,0"
                    BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}">
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsSentTab}" Value="True">
                        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SwitchTabCommand}" CommandParameter="sent" />
                </Border.GestureRecognizers>
                <Label Text="📤 Envoyées"
                       FontSize="14"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsSentTab}" Value="True">
                            <Setter Property="TextColor" Value="White" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Border>
        </Grid>

        <!-- Liste Reçues -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsBusy}"
                     IsVisible="{Binding IsReceivedTab}">
            <ScrollView>
                <VerticalStackLayout>
                    <CollectionView ItemsSource="{Binding Received}"
                                    ItemTemplate="{StaticResource ProposalTemplate}"
                                    SelectionMode="None"
                                    EmptyView="Aucune proposition reçue pour le moment." />
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>

        <!-- Liste Envoyées -->
        <RefreshView Grid.Row="1"
                     Command="{Binding RefreshCommand}"
                     IsRefreshing="{Binding IsBusy}"
                     IsVisible="{Binding IsSentTab}">
            <ScrollView>
                <VerticalStackLayout>
                    <CollectionView ItemsSource="{Binding Sent}"
                                    ItemTemplate="{StaticResource ProposalTemplate}"
                                    SelectionMode="None"
                                    EmptyView="Vous n'avez encore envoyé aucune proposition." />
                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>
</ContentPage>

