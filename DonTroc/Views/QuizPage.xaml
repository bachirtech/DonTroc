<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:DonTroc.ViewModels"
             xmlns:views="clr-namespace:DonTroc.Views"
             x:Class="DonTroc.Views.QuizPage"
             x:DataType="vm:QuizViewModel"
             Title="Quiz du Jour"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="QuizPrimaryColor">#4CAF50</Color>
            <Color x:Key="QuizCorrectColor">#4CAF50</Color>
            <Color x:Key="QuizWrongColor">#F44336</Color>
            <Color x:Key="QuizSelectedColor">#2196F3</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <!-- Écran d'accueil du Quiz -->
        <ScrollView IsVisible="{Binding IsQuizActive, Converter={StaticResource InverseBoolConverter}}">
            <VerticalStackLayout Padding="20" Spacing="20">
                
                <!-- En-tête -->
                <Border StrokeShape="RoundRectangle 20"
                        BackgroundColor="#E8F5E9"
                        Padding="20"
                        Margin="0,10,0,0">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="🧠" FontSize="60" HorizontalOptions="Center"/>
                        <Label Text="Quiz du Jour" 
                               FontSize="28" 
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="#2E7D32"/>
                        <Label Text="Testez vos connaissances sur l'écologie, le recyclage et la solidarité !"
                               FontSize="14"
                               HorizontalTextAlignment="Center"
                               TextColor="#666666"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Stats utilisateur -->
                <Border StrokeShape="RoundRectangle 15"
                        BackgroundColor="White"
                        Padding="15"
                        IsVisible="{Binding UserProfile, Converter={StaticResource NullToBoolConverter}}">
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding UserProfile.TotalQuizzesCompleted}" 
                                   FontSize="24" 
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"
                                   HorizontalOptions="Center"/>
                            <Label Text="Quiz joués" 
                                   FontSize="11" 
                                   TextColor="#666666"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding UserProfile.OverallSuccessRate, StringFormat='{0:F0}%'}" 
                                   FontSize="24" 
                                   FontAttributes="Bold"
                                   TextColor="#2196F3"
                                   HorizontalOptions="Center"/>
                            <Label Text="Réussite" 
                                   FontSize="11" 
                                   TextColor="#666666"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                            <HorizontalStackLayout HorizontalOptions="Center">
                                <Label Text="🔥" FontSize="20"/>
                                <Label Text="{Binding CurrentStreak}" 
                                       FontSize="24" 
                                       FontAttributes="Bold"
                                       TextColor="#FF9800"/>
                            </HorizontalStackLayout>
                            <Label Text="Streak" 
                                   FontSize="11" 
                                   TextColor="#666666"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Bouton Quiz Quotidien -->
                <Border StrokeShape="RoundRectangle 15"
                        BackgroundColor="White"
                        Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <HorizontalStackLayout Spacing="10">
                            <Label Text="📅" FontSize="30"/>
                            <VerticalStackLayout>
                                <Label Text="Quiz Quotidien" 
                                       FontSize="18" 
                                       FontAttributes="Bold"/>
                                <Label Text="3 questions • Gagnez des XP !"
                                       FontSize="12"
                                       TextColor="#666666"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        
                        <Button Text="{Binding CanPlayDailyQuiz, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Jouer maintenant|Déjà joué aujourd\x27hui'}"
                                Command="{Binding StartDailyQuizCommand}"
                                IsEnabled="{Binding CanPlayDailyQuiz}"
                                BackgroundColor="{Binding CanPlayDailyQuiz, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#4CAF50|#BDBDBD'}"
                                TextColor="White"
                                FontAttributes="Bold"
                                HeightRequest="50"
                                CornerRadius="10"/>
                        
                        <Label Text="⏰ Revenez demain pour un nouveau quiz !"
                               IsVisible="{Binding CanPlayDailyQuiz, Converter={StaticResource InverseBoolConverter}}"
                               FontSize="12"
                               TextColor="#FF9800"
                               HorizontalTextAlignment="Center"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Quiz Thématiques -->
                <Label Text="Quiz Thématiques" 
                       FontSize="18" 
                       FontAttributes="Bold"
                       Margin="0,10,0,0"/>
                
                <Grid ColumnDefinitions="*,*" 
                      RowDefinitions="Auto,Auto,Auto"
                      ColumnSpacing="10" 
                      RowSpacing="10">
                    
                    <!-- Écologie -->
                    <Border Grid.Row="0" Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#E8F5E9"
                            Padding="15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding StartThematicQuizCommand}" 
                                                  CommandParameter="Ecologie"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🌍" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Écologie" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Recyclage -->
                    <Border Grid.Row="0" Grid.Column="1"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#E3F2FD"
                            Padding="15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding StartThematicQuizCommand}" 
                                                  CommandParameter="Recyclage"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="♻️" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Recyclage" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Solidarité -->
                    <Border Grid.Row="1" Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#FCE4EC"
                            Padding="15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding StartThematicQuizCommand}" 
                                                  CommandParameter="Solidarite"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🤝" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Solidarité" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Économie Circulaire -->
                    <Border Grid.Row="1" Grid.Column="1"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#FFF3E0"
                            Padding="15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding StartThematicQuizCommand}" 
                                                  CommandParameter="EconomieCirculaire"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="🔄" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Éco. Circulaire" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Astuces -->
                    <Border Grid.Row="2" Grid.Column="0"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#F3E5F5"
                            Padding="15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding StartThematicQuizCommand}" 
                                                  CommandParameter="Astuces"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="💡" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Astuces" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Culture -->
                    <Border Grid.Row="2" Grid.Column="1"
                            StrokeShape="RoundRectangle 12"
                            BackgroundColor="#EFEBE9"
                            Padding="15">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding StartThematicQuizCommand}" 
                                                  CommandParameter="Culture"/>
                        </Border.GestureRecognizers>
                        <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                            <Label Text="📚" FontSize="35" HorizontalOptions="Center"/>
                            <Label Text="Culture" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
                
                <!-- Quiz Bonus - Débloquable avec pub -->
                <Border StrokeShape="RoundRectangle 15"
                        BackgroundColor="#FFF8E1"
                        Stroke="#FFD54F"
                        StrokeThickness="2"
                        Padding="15"
                        IsVisible="{Binding CanUnlockBonusQuiz}">
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🎁" FontSize="30"/>
                            <VerticalStackLayout>
                                <Label Text="Quiz Bonus" 
                                       FontSize="18" 
                                       FontAttributes="Bold"
                                       TextColor="#F57C00"/>
                                <Label Text="Questions exclusives • Récompenses doublées"
                                       FontSize="12"
                                       TextColor="#666666"/>
                            </VerticalStackLayout>
                        </HorizontalStackLayout>
                        
                        <Button Text="📺 Débloquer avec une pub"
                                Command="{Binding UnlockBonusQuizCommand}"
                                BackgroundColor="#FF9800"
                                TextColor="White"
                                FontAttributes="Bold"
                                HeightRequest="45"
                                CornerRadius="10"/>
                    </VerticalStackLayout>
                </Border>
                
                <!-- Message Quiz Bonus déjà débloqué -->
                <Border StrokeShape="RoundRectangle 15"
                        BackgroundColor="#E8F5E9"
                        Stroke="#81C784"
                        StrokeThickness="2"
                        Padding="15"
                        IsVisible="{Binding HasBonusQuizUnlocked}">
                    <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Label Text="✅" FontSize="24"/>
                        <Label Text="Quiz Bonus débloqué pour aujourd'hui !"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#388E3C"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>
                
                <!-- Bannière Publicitaire -->
                <views:AdBannerView HorizontalOptions="Center"
                                    Margin="0,10,0,0"/>
                
            </VerticalStackLayout>
        </ScrollView>

        <!-- Écran de Quiz Actif -->
        <Grid IsVisible="{Binding IsQuizActive}"
              RowDefinitions="Auto,*,Auto"
              Padding="20">
            
            <!-- En-tête du quiz -->
            <VerticalStackLayout Grid.Row="0" Spacing="10">
                <!-- Barre de progression -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Label Grid.Column="0" 
                           Text="{Binding QuestionNumber, StringFormat='Question {0}'}"
                           FontSize="14"
                           TextColor="#666666"/>
                    <ProgressBar Grid.Column="1" 
                                 Progress="{Binding Progress}"
                                 ProgressColor="#4CAF50"
                                 VerticalOptions="Center"/>
                    <Label Grid.Column="2"
                           Text="{Binding TotalQuestions, StringFormat='/ {0}'}"
                           FontSize="14"
                           TextColor="#666666"/>
                </Grid>
                
                <!-- Timer et catégorie -->
                <Grid ColumnDefinitions="*,Auto">
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="{Binding CategoryColor}"
                            Padding="8,4"
                            HorizontalOptions="Start">
                        <Label Text="{Binding CategoryName}" 
                               TextColor="White" 
                               FontSize="12"/>
                    </Border>
                    
                    <Border Grid.Column="1"
                            StrokeShape="RoundRectangle 20"
                            BackgroundColor="{Binding TimeRemaining, Converter={StaticResource IntToColorConverter}, ConverterParameter='10|#FF5722|#4CAF50'}"
                            Padding="12,6"
                            HorizontalOptions="End">
                        <HorizontalStackLayout Spacing="5">
                            <Label Text="⏱️" FontSize="16"/>
                            <Label Text="{Binding TimeRemaining, StringFormat='{0}s'}" 
                                   TextColor="White" 
                                   FontAttributes="Bold"
                                   FontSize="16"/>
                        </HorizontalStackLayout>
                    </Border>
                </Grid>
                
                <!-- Bouton Temps Bonus (visible quand le temps est faible) -->
                <Border StrokeShape="RoundRectangle 10"
                        BackgroundColor="#FFF3E0"
                        Stroke="#FFB74D"
                        StrokeThickness="1"
                        Padding="10"
                        IsVisible="{Binding CanAddExtraTime}">
                    <Grid ColumnDefinitions="*,Auto">
                        <HorizontalStackLayout Grid.Column="0" Spacing="8">
                            <Label Text="⏰" FontSize="18" VerticalOptions="Center"/>
                            <Label Text="Temps presque écoulé !"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#E65100"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        <Button Grid.Column="1"
                                Text="📺 +15s"
                                Command="{Binding AddExtraTimeCommand}"
                                BackgroundColor="#FF9800"
                                TextColor="White"
                                FontSize="12"
                                FontAttributes="Bold"
                                HeightRequest="35"
                                Padding="10,0"
                                CornerRadius="8"/>
                    </Grid>
                </Border>
            </VerticalStackLayout>
            
            <!-- Question et réponses -->
            <ScrollView Grid.Row="1" Margin="0,20">
                <VerticalStackLayout Spacing="15">
                    <!-- Question -->
                    <Border StrokeShape="RoundRectangle 15"
                            BackgroundColor="White"
                            Padding="20">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="{Binding CurrentQuestion.Icon}" 
                                   FontSize="40" 
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding CurrentQuestion.Question}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Options de réponse -->
                    <VerticalStackLayout Spacing="10" 
                                         BindableLayout.ItemsSource="{Binding AnswerOptions}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuizAnswerOption">
                                <Border StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{Binding BackgroundColor}"
                                        Stroke="{Binding BorderColor}"
                                        StrokeThickness="2"
                                        Padding="15"
                                        x:Name="AnswerBorder">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnAnswerTapped" 
                                                              CommandParameter="{Binding Index}"/>
                                    </Border.GestureRecognizers>
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Border Grid.Column="0"
                                                StrokeShape="RoundRectangle 15"
                                                BackgroundColor="{Binding BorderColor}"
                                                WidthRequest="30"
                                                HeightRequest="30">
                                            <Label Text="{Binding Index, Converter={StaticResource IndexToLetterConverter}}"
                                                   TextColor="White"
                                                   FontAttributes="Bold"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        <Label Grid.Column="1"
                                               Text="{Binding Text}"
                                               FontSize="15"
                                               VerticalOptions="Center"
                                               LineBreakMode="WordWrap"/>
                                        <Label Grid.Column="2"
                                               Text="{Binding IsCorrect, Converter={StaticResource BoolToTextConverter}, ConverterParameter='✓|'}"
                                               IsVisible="{Binding ShowResult}"
                                               TextColor="#4CAF50"
                                               FontSize="20"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    
                    <!-- Explication après réponse -->
                    <Border StrokeShape="RoundRectangle 12"
                            BackgroundColor="{Binding LastAnswerCorrect, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#E8F5E9|#FFEBEE'}"
                            Padding="15"
                            IsVisible="{Binding ShowQuestionResult}">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding LastAnswerCorrect, Converter={StaticResource BoolToTextConverter}, ConverterParameter='✅|❌'}" 
                                       FontSize="24"/>
                                <Label Text="{Binding LastAnswerCorrect, Converter={StaticResource BoolToTextConverter}, ConverterParameter='Bonne réponse !|Mauvaise réponse'}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{Binding LastAnswerCorrect, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#2E7D32|#C62828'}"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="{Binding Explanation}"
                                   FontSize="14"
                                   TextColor="#555555"
                                   LineBreakMode="WordWrap"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Bouton Seconde Chance (visible après une mauvaise réponse) -->
                    <Border StrokeShape="RoundRectangle 12"
                            BackgroundColor="#FFF8E1"
                            Stroke="#FFD54F"
                            StrokeThickness="2"
                            Padding="15"
                            IsVisible="{Binding CanUseSecondChance}">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="🎯" FontSize="24"/>
                                <Label Text="Seconde Chance !"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#F57C00"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                            <Label Text="Regardez une pub pour retenter cette question"
                                   FontSize="12"
                                   TextColor="#666666"
                                   HorizontalTextAlignment="Center"/>
                            
                            <Button Text="📺 Obtenir une seconde chance"
                                    Command="{Binding SecondChanceCommand}"
                                    IsEnabled="{Binding IsLoadingAd, Converter={StaticResource InverseBoolConverter}}"
                                    BackgroundColor="#FF9800"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    HeightRequest="45"
                                    CornerRadius="10"/>
                            
                            <ActivityIndicator IsRunning="{Binding IsLoadingAd}"
                                               IsVisible="{Binding IsLoadingAd}"
                                               HeightRequest="20"
                                               Color="#FF9800"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
            
            <!-- Bouton suivant -->
            <Button Grid.Row="2"
                    Text="Question suivante →"
                    Command="{Binding NextQuestionCommand}"
                    IsVisible="{Binding ShowQuestionResult}"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    HeightRequest="55"
                    CornerRadius="12"/>
        </Grid>

        <!-- Écran de résultat -->
        <Grid IsVisible="{Binding ShowResult}"
              BackgroundColor="#F5F5F5"
              Padding="20">
            <Border StrokeShape="RoundRectangle 20"
                    BackgroundColor="White"
                    Padding="25"
                    VerticalOptions="Center"
                    MaximumWidthRequest="400">
                <VerticalStackLayout Spacing="20" HorizontalOptions="Center">
                    
                    <!-- Icône et titre -->
                    <Label Text="{Binding ResultIcon}" 
                           FontSize="80" 
                           HorizontalOptions="Center"/>
                    <Label Text="{Binding ResultTitle}"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"/>
                    
                    <!-- Score -->
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="20" RowSpacing="10">
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0" HorizontalOptions="Center">
                            <Label Text="{Binding CorrectAnswers, StringFormat='{0}'}"
                                   FontSize="36"
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"
                                   HorizontalOptions="Center"/>
                            <Label Text="Bonnes réponses"
                                   FontSize="12"
                                   TextColor="#666666"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                        
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1" HorizontalOptions="Center">
                            <Label Text="{Binding TotalXpEarned, StringFormat='+{0}'}"
                                   FontSize="36"
                                   FontAttributes="Bold"
                                   TextColor="#FF9800"
                                   HorizontalOptions="Center"/>
                            <Label Text="XP gagnés"
                                   FontSize="12"
                                   TextColor="#666666"
                                   HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Grid>
                    
                    <!-- Bonus XP affiché après avoir regardé la pub -->
                    <Border StrokeShape="RoundRectangle 10"
                            BackgroundColor="#E8F5E9"
                            Padding="12"
                            IsVisible="{Binding BonusXpEarned, Converter={StaticResource IntToBoolConverter}}">
                        <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                            <Label Text="🎁" FontSize="20"/>
                            <Label Text="{Binding BonusXpEarned, StringFormat='Bonus: +{0} XP'}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="#2E7D32"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                    
                    <!-- Bouton Doubler les XP avec Rewarded Ad -->
                    <Border StrokeShape="RoundRectangle 12"
                            BackgroundColor="#FFF8E1"
                            Stroke="#FFD54F"
                            StrokeThickness="2"
                            Padding="15"
                            IsVisible="{Binding CanDoubleXp}">
                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="🎬" FontSize="24"/>
                                <Label Text="Doublez vos XP !"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#F57C00"
                                       VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            
                            <Label Text="Regardez une courte publicité pour doubler vos XP gagnés"
                                   FontSize="12"
                                   TextColor="#666666"
                                   HorizontalTextAlignment="Center"/>
                            
                            <Button Text="📺 Regarder et doubler mes XP"
                                    Command="{Binding DoubleXpCommand}"
                                    IsEnabled="{Binding IsLoadingAd, Converter={StaticResource InverseBoolConverter}}"
                                    BackgroundColor="#FF9800"
                                    TextColor="White"
                                    FontAttributes="Bold"
                                    HeightRequest="45"
                                    CornerRadius="10"/>
                            
                            <ActivityIndicator IsRunning="{Binding IsLoadingAd}"
                                               IsVisible="{Binding IsLoadingAd}"
                                               HeightRequest="20"
                                               Color="#FF9800"/>
                        </VerticalStackLayout>
                    </Border>
                    
                    <!-- Streak -->
                    <Border StrokeShape="RoundRectangle 10"
                            BackgroundColor="#FFF3E0"
                            Padding="15"
                            IsVisible="{Binding CurrentStreak, Converter={StaticResource IntToBoolConverter}}">
                        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                            <Label Text="🔥" FontSize="24"/>
                            <Label Text="{Binding CurrentStreak, StringFormat='Streak de {0} jours !'}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#E65100"
                                   VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                    </Border>
                    
                    <!-- Message -->
                    <Label Text="{Binding ResultMessage}"
                           FontSize="14"
                           TextColor="#666666"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap"/>
                    
                    <!-- Boutons -->
                    <VerticalStackLayout Spacing="10">
                        <Button Text="Retour à l'accueil"
                                Command="{Binding CloseQuizCommand}"
                                BackgroundColor="#4CAF50"
                                TextColor="White"
                                FontAttributes="Bold"
                                HeightRequest="50"
                                CornerRadius="10"/>
                    </VerticalStackLayout>
                    
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Loading -->
        <ActivityIndicator IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           Color="#4CAF50"/>
    </Grid>
</ContentPage>

