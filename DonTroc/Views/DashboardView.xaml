                                        <Label Text="📺 Regarder"
                                               FontSize="10"
                                               TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                               HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Boost annonce -->
                                <Border Grid.Column="1" Grid.Row="0"
                                        StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#F0F8E8, Dark=#2A3D22}"
                                        Padding="14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding WatchAdForBoostCreditsCommand}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                        <Border StrokeShape="RoundRectangle 14,14,14,14"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light=#E0F0D0, Dark=#3A4D32}"
                                                WidthRequest="40" HeightRequest="40"
                                                HorizontalOptions="Center">
                                            <Label Text="🚀" FontSize="20"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <Label Text="Boost annonce"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                               HorizontalTextAlignment="Center" />
                                        <Label Text="📺 Regarder"
                                               FontSize="10"
                                               TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                               HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Statistiques avancées -->
                                <Border Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                        StrokeShape="RoundRectangle 14,14,14,14"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#F0EBFF, Dark=#3D3557}"
                                        Padding="14">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding WatchAdForStatsCommand}" />
                                    </Border.GestureRecognizers>
                                    <StackLayout Orientation="Horizontal" Spacing="12" HorizontalOptions="Center">
                                        <Border StrokeShape="RoundRectangle 14,14,14,14"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light=#E0D8F0, Dark=#4D4567}"
                                                WidthRequest="40" HeightRequest="40">
                                            <Label Text="📊" FontSize="20"
                                                   HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <StackLayout Spacing="2" VerticalOptions="Center">
                                            <Label Text="Statistiques avancées (24h)"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                                            <Label Text="📺 Regarder une publicité"
                                                   FontSize="10"
                                                   TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />
                                        </StackLayout>
                                    </StackLayout>
                                </Border>
                            </Grid>

                            <!-- Statut Ad-free actif -->
                            <Border StrokeShape="RoundRectangle 10,10,10,10"
                                    StrokeThickness="0"
                                    Padding="10,6"
                                    IsVisible="{Binding IsAdFreeActive}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#8DAE6A}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#8DB86A, Dark=#6B9A4E}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Label
                                    Text="{Binding AdFreeUntil, StringFormat=&quot;✨ Mode sans pub actif jusqu&apos;à {0:HH:mm}&quot;}"
                                    TextColor="White"
                                    FontSize="12"
                                    FontAttributes="Bold"
                                    HorizontalTextAlignment="Center" />
                            </Border>

                            <!-- Statut boost crédits -->
                            <Border StrokeShape="RoundRectangle 10,10,10,10"
                                    StrokeThickness="0"
                                    Padding="10,6"
                                    IsVisible="{Binding BoostCredits, Converter={StaticResource IntToBoolConverter}}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#C47A58, Dark=#A06842}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Label Text="{Binding BoostCredits, StringFormat='🚀 {0} crédits de boost disponibles'}"
                                       TextColor="White"
                                       FontSize="12"
                                       FontAttributes="Bold"
                                       HorizontalTextAlignment="Center" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Espace en bas -->
                    <BoxView HeightRequest="10" BackgroundColor="Transparent" />

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>

    <!-- Pop-up récompense quotidienne -->
    <views:DailyRewardPopup x:Name="DailyRewardOverlay" />

    <!-- Overlay pour les conseils -->
    <views:TipOverlayView x:Name="TipOverlay" />
    </Grid>
</ContentPage>


