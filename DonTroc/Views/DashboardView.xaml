<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             xmlns:models="clr-namespace:DonTroc.Models"
             xmlns:views="clr-namespace:DonTroc.Views"
             xmlns:services="clr-namespace:DonTroc.Services"
             x:DataType="viewModels:DashboardViewModel"
             x:Class="DonTroc.Views.DashboardView"
             x:Name="DashboardPageRoot"
             Title="Accueil"
             BackgroundColor="{AppThemeBinding Light={StaticResource BeigeClair}, Dark={StaticResource BeigeSombre}}">

    <Grid>
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Spacing="0">

                <!-- ═══════════════════════════════════════════════ -->
                <!-- HEADER GRADIENT PLEINE LARGEUR                 -->
                <!-- ═══════════════════════════════════════════════ -->
                <Border StrokeThickness="0"
                        StrokeShape="RoundRectangle 0,0,28,28"
                        Padding="20,15,20,25">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#8B5A3A}" Offset="0.0" />
                            <GradientStop Color="{AppThemeBinding Light=#C47A58, Dark=#6B4A32}" Offset="0.5" />
                            <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#5A7A3E}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="#40000000" Offset="0,6" Radius="16" Opacity="0.3" />
                    </Border.Shadow>

                    <VerticalStackLayout Spacing="12">
                        <!-- Bannière pub -->
                        <views:AdBannerView
                            HeightRequest="50"
                            MinimumHeightRequest="50"
                            HorizontalOptions="Fill"
                            BackgroundColor="Transparent" />

                        <!-- Logo + Message d'accueil -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="15" Padding="0,5,0,0">
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle 18,18,18,18"
                                    StrokeThickness="0"
                                    BackgroundColor="#33FFFFFF"
                                    WidthRequest="64" HeightRequest="64"
                                    HorizontalOptions="Center" VerticalOptions="Center">
                                <Image Source="logotroc.png"
                                       HeightRequest="48" WidthRequest="48"
                                       Aspect="AspectFit"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                <Label Text="DonTroc"
                                       FontSize="26"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       FontFamily="PoppinsBold" />
                                <Label Text="{Binding MessageAccueil}"
                                       FontSize="14"
                                       TextColor="#E0FFFFFF"
                                       LineBreakMode="TailTruncation"
                                       MaxLines="2" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- ═══════════════════════════════════════════════ -->
                <!-- CONTENU PRINCIPAL                               -->
                <!-- ═══════════════════════════════════════════════ -->
                <VerticalStackLayout Padding="18,0,18,20" Spacing="18" Margin="0,-12,0,0">

                    <!-- ─── WIDGET STREAK + GAMIFICATION ─── -->
                    <Border StrokeShape="RoundRectangle 18,18,18,18"
                            StrokeThickness="0"
                            Padding="16,14"
                            IsVisible="{Binding HasStreak}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="{AppThemeBinding Light=#FF8C42, Dark=#CC6B30}" Offset="0.0" />
                                <GradientStop Color="{AppThemeBinding Light=#FF6B35, Dark=#B8522A}" Offset="1.0" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#40FF6B35, Dark=#30000000}" Offset="0,4" Radius="12" Opacity="0.5" />
                        </Border.Shadow>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding GoToRewardsCommand}" />
                        </Border.GestureRecognizers>

                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                            <!-- Icône streak -->
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle 14,14,14,14"
                                    StrokeThickness="0"
                                    BackgroundColor="#33FFFFFF"
                                    WidthRequest="48" HeightRequest="48"
                                    HorizontalOptions="Center" VerticalOptions="Center">
                                <Label x:Name="DashboardStreakFlame"
                                       Text="🔥" FontSize="24"
                                       HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>

                            <!-- Texte streak -->
                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label TextColor="White" FontSize="16" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding StreakCount}" FontSize="20" FontAttributes="Bold" />
                                            <Span Text=" jours de série" FontSize="14" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label TextColor="#E0FFFFFF" FontSize="12">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Niv. " />
                                            <Span Text="{Binding UserLevel}" FontAttributes="Bold" />
                                            <Span Text=" · " />
                                            <Span Text="{Binding UserTitle}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>

                            <!-- XP badge -->
                            <Border Grid.Column="2"
                                    StrokeShape="RoundRectangle 12,12,12,12"
                                    StrokeThickness="0"
                                    BackgroundColor="#33FFFFFF"
                                    Padding="10,6"
                                    VerticalOptions="Center">
                                <Label TextColor="White" FontSize="13" FontAttributes="Bold">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="✨ " />
                                            <Span Text="{Binding UserXp}" />
                                            <Span Text=" XP" FontSize="10" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ─── CHECKLIST ONBOARDING "PREMIERS PAS" ─── -->
                    <Border StrokeShape="RoundRectangle 18,18,18,18"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                            Padding="16,14"
                            IsVisible="{Binding IsChecklistVisible}">
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#20A8C686, Dark=#30000000}" Offset="0,4" Radius="14" Opacity="0.4" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="12">
                            <!-- En-tête avec titre + bouton fermer -->
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                <Border Grid.Column="0"
                                        StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E8F5E0, Dark=#2A3D22}"
                                        WidthRequest="40" HeightRequest="40"
                                        HorizontalOptions="Center" VerticalOptions="Center">
                                    <Label Text="🚀" FontSize="20"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                    <Label Text="Premiers pas"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                                    <Label FontSize="11"
                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                           Opacity="0.6">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding ChecklistCompletedCount}" FontAttributes="Bold" />
                                                <Span Text="/" />
                                                <Span Text="{Binding ChecklistTotalSteps}" />
                                                <Span Text=" complétées · +25 XP chacune" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                </VerticalStackLayout>
                                <!-- Bouton fermer -->
                                <Border Grid.Column="2"
                                        StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#F0E8DE, Dark=#3D3326}"
                                        WidthRequest="32" HeightRequest="32"
                                        HorizontalOptions="Center" VerticalOptions="Center">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding DismissChecklistCommand}" />
                                    </Border.GestureRecognizers>
                                    <Label Text="✕" FontSize="14"
                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                           Opacity="0.5"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                            </Grid>

                            <!-- Barre de progression -->
                            <Grid RowDefinitions="Auto" ColumnDefinitions="*" Margin="0,2,0,0">
                                <Border StrokeShape="RoundRectangle 6,6,6,6"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E8E0D8, Dark=#3D3326}"
                                        HeightRequest="8"
                                        HorizontalOptions="Fill" />
                                <Border StrokeShape="RoundRectangle 6,6,6,6"
                                        StrokeThickness="0"
                                        HeightRequest="8"
                                        HorizontalOptions="Start"
                                        WidthRequest="0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#5A7A3E}" Offset="0.0" />
                                            <GradientStop Color="{AppThemeBinding Light=#8FB86E, Dark=#4A6A2E}" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ChecklistCompletedCount}"
                                                     Value="1">
                                            <Setter Property="WidthRequest" Value="60" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ChecklistCompletedCount}"
                                                     Value="2">
                                            <Setter Property="WidthRequest" Value="120" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ChecklistCompletedCount}"
                                                     Value="3">
                                            <Setter Property="WidthRequest" Value="180" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ChecklistCompletedCount}"
                                                     Value="4">
                                            <Setter Property="WidthRequest" Value="240" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding ChecklistCompletedCount}"
                                                     Value="5">
                                            <Setter Property="WidthRequest" Value="300" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            </Grid>

                            <!-- Liste des étapes -->
                            <VerticalStackLayout BindableLayout.ItemsSource="{Binding ChecklistSteps}" Spacing="6">
                                <BindableLayout.ItemTemplate>
                                    <DataTemplate x:DataType="services:OnboardingStep">
                                        <Border StrokeShape="RoundRectangle 12,12,12,12"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light=#F8F5F0, Dark=#2D2520}"
                                                Padding="12,10">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:DashboardViewModel}}, Path=ChecklistStepTappedCommand}"
                                                    CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                                <!-- Icône état (✅ ou emoji de l'étape) -->
                                                <Label Grid.Column="0"
                                                       FontSize="20"
                                                       VerticalOptions="Center"
                                                       HorizontalOptions="Center">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding IsCompleted}"
                                                                     Value="True">
                                                            <Setter Property="Text" Value="✅" />
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label"
                                                                     Binding="{Binding IsCompleted}"
                                                                     Value="False">
                                                            <Setter Property="Text" Value="{Binding Icon}" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                                <!-- Texte de l'étape -->
                                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                                    <Label Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />
                                                    <Label Text="{Binding Description}"
                                                           FontSize="11"
                                                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                                           Opacity="0.6" />
                                                </VerticalStackLayout>
                                                <!-- Récompense XP ou chevron -->
                                                <Border Grid.Column="2"
                                                        StrokeShape="RoundRectangle 8,8,8,8"
                                                        StrokeThickness="0"
                                                        Padding="8,4"
                                                        VerticalOptions="Center"
                                                        IsVisible="{Binding IsCompleted, Converter={StaticResource InverseBoolConverter}}"
                                                        BackgroundColor="{AppThemeBinding Light=#FFF5EE, Dark=#3D2E24}">
                                                    <Label Text="+25 XP"
                                                           FontSize="10"
                                                           FontAttributes="Bold"
                                                           TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </BindableLayout.ItemTemplate>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ─── STATISTIQUES UTILISATEUR ─── -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                        <!-- Carte Mes Annonces -->
                        <Border Grid.Column="0"
                                StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=#F0FFFFFF, Dark=#30FFFFFF}"
                                Padding="16,18">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#25D98C6A, Dark=#20000000}" Offset="0,4" Radius="12" Opacity="0.5" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border StrokeShape="RoundRectangle 16,16,16,16"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#FFEDE3, Dark=#3D2E24}"
                                        WidthRequest="44" HeightRequest="44"
                                        HorizontalOptions="Center">
                                    <Label Text="📦" FontSize="22"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding NombreMesAnnonces}"
                                       FontSize="32"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Mes annonces"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       HorizontalTextAlignment="Center"
                                       Opacity="0.8" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Carte Conversations -->
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 18,18,18,18"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light=#F0FFFFFF, Dark=#30FFFFFF}"
                                Padding="16,18">
                            <Border.Shadow>
                                <Shadow Brush="{AppThemeBinding Light=#25A8C686, Dark=#20000000}" Offset="0,4" Radius="12" Opacity="0.5" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                                <Border StrokeShape="RoundRectangle 16,16,16,16"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#E8F5E0, Dark=#2A3D22}"
                                        WidthRequest="44" HeightRequest="44"
                                        HorizontalOptions="Center">
                                    <Label Text="💬" FontSize="22"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="{Binding NombreConversations}"
                                       FontSize="32"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Conversations"
                                       FontSize="12"
                                       TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                       HorizontalTextAlignment="Center"
                                       Opacity="0.8" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- ─── ACTIONS RAPIDES ─── -->
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Actions rapides"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                               Margin="4,0,0,0" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                            <!-- Bouton Donner -->
                            <Border Grid.Column="0"
                                    StrokeShape="RoundRectangle 20,20,20,20"
                                    StrokeThickness="0"
                                    Padding="0"
                                    HeightRequest="60">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#E5A07E, Dark=#C47A58}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#40D98C6A, Dark=#30000000}" Offset="0,4" Radius="10" Opacity="0.6" />
                                </Border.Shadow>
                                <Button x:Name="DonnerButton"
                                        Text="🎁 Donner"
                                        Command="{Binding GoToCreationAnnonceCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="White"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        FontFamily="PoppinsBold"
                                        CornerRadius="20"
                                        Padding="0" />
                            </Border>

                            <!-- Bouton Explorer -->
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 20,20,20,20"
                                    StrokeThickness="0"
                                    Padding="0"
                                    HeightRequest="60">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#8DAE6A}" Offset="0.0" />
                                        <GradientStop Color="{AppThemeBinding Light=#B8D696, Dark=#9ABE7A}" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Shadow>
                                    <Shadow Brush="{AppThemeBinding Light=#40A8C686, Dark=#30000000}" Offset="0,4" Radius="10" Opacity="0.6" />
                                </Border.Shadow>
                                <Button x:Name="ExplorerButton"
                                        Text="🔍 Explorer"
                                        Command="{Binding GoToAnnoncesCommand}"
                                        BackgroundColor="Transparent"
                                        TextColor="White"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        FontFamily="PoppinsBold"
                                        CornerRadius="20"
                                        Padding="0" />
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- ─── ACTIVITÉ RÉCENTE ─── -->
                    <Border StrokeShape="RoundRectangle 18,18,18,18"
                            StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                            Padding="16,14"
                            IsVisible="{Binding HasActiviteRecente}">
                        <Border.Shadow>
                            <Shadow Brush="{AppThemeBinding Light=#15000000, Dark=#30000000}" Offset="0,3" Radius="10" Opacity="0.3" />
                        </Border.Shadow>

                        <VerticalStackLayout Spacing="12">
                            <Label Text="📊 Activité récente"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}" />

                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                                <!-- Messages non lus -->
                                <Border Grid.Column="0"
                                        StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#FFF0E6, Dark=#3D2E24}"
                                        Padding="10,12"
                                        IsVisible="{Binding NombreMessagesNonLus, Converter={StaticResource IntToBoolConverter}}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToMessagesCommand}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="💬" FontSize="20" HorizontalTextAlignment="Center" />
                                        <Label Text="{Binding NombreMessagesNonLus, StringFormat='{0} non lu(s)'}"
                                               FontSize="10"
                                               TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Badges débloqués -->
                                <Border Grid.Column="1"
                                        StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#F0F8E8, Dark=#2A3D22}"
                                        Padding="10,12"
                                        IsVisible="{Binding NombreBadgesDebloques, Converter={StaticResource IntToBoolConverter}}">
                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding GoToRewardsCommand}" />
                                    </Border.GestureRecognizers>
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="🏅" FontSize="20" HorizontalTextAlignment="Center" />
                                        <Label Text="{Binding NombreBadgesDebloques, StringFormat='{0} badge(s)'}"
                                               FontSize="10"
                                               TextColor="{AppThemeBinding Light={StaticResource VertSauge}, Dark={StaticResource VertSaugeSombre}}"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Favoris -->
                                <Border Grid.Column="2"
                                        StrokeShape="RoundRectangle 12,12,12,12"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#FFF5F0, Dark=#3D3326}"
                                        Padding="10,12"
                                        IsVisible="{Binding NombreFavoris, Converter={StaticResource IntToBoolConverter}}">
                                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                                        <Label Text="❤️" FontSize="20" HorizontalTextAlignment="Center" />
                                        <Label Text="{Binding NombreFavoris, StringFormat='{0} favori(s)'}"
                                               FontSize="10"
                                               TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="Center"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- ─── 🏪 ÉVÉNEMENTS À VENIR (CARROUSEL) ─── -->
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" Margin="4,0">
                            <Label Grid.Column="0"
                                   Text="🏪 Événements à venir"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                                   VerticalTextAlignment="Center" />
                            <Label Grid.Column="1"
                                   Text="Voir tout ›" FontSize="14" FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                                   VerticalTextAlignment="Center">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToEventsCommand}" />
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>

                        <!-- Carrousel (visible quand des événements existent) -->
                        <CollectionView ItemsSource="{Binding EvenementsAVenir}"
                                        HeightRequest="170"
                                        SelectionMode="None"
                                        IsVisible="{Binding HasEvenements}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Evenement">
                                    <Border WidthRequest="240"
                                            StrokeShape="RoundRectangle 16,16,16,16"
                                            StrokeThickness="0" Padding="0">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#D98C6A" Offset="0.0" />
                                                <GradientStop Color="#A8C686" Offset="1.0" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference DashboardPageRoot}, Path=BindingContext.OpenEventDetailCommand}"
                                                                  CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <VerticalStackLayout Padding="14" Spacing="6">
                                            <Label Text="{Binding CountdownText}" FontSize="11" FontAttributes="Bold" TextColor="White" Opacity="0.9" />
                                            <Label Text="{Binding Titre}" FontAttributes="Bold" FontSize="16" TextColor="White" MaxLines="2" LineBreakMode="TailTruncation" />
