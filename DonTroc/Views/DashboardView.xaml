<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             xmlns:models="clr-namespace:DonTroc.Models"
             xmlns:views="clr-namespace:DonTroc.Views"
             x:DataType="viewModels:DashboardViewModel"
             x:Class="DonTroc.Views.DashboardView"
             Title="Accueil"
             BackgroundColor="{StaticResource BeigeClair}">

    <Grid>
    <RefreshView Command="{Binding RefreshCommand}" IsRefreshing="{Binding IsBusy}">
        <ScrollView>
            <VerticalStackLayout Padding="20,0,20,20" Spacing="20">

                <!-- Bannière publicitaire en haut -->
                <views:AdBannerView
                    HeightRequest="60"
                    MinimumHeightRequest="60"
                    HorizontalOptions="Fill"
                    VerticalOptions="Start"
                    BackgroundColor="LightGray"
                    Margin="0,10,0,0" />

                <!-- En-tête avec logo et message d'accueil -->
                <Frame BackgroundColor="White"
                       CornerRadius="15"
                       HasShadow="True"
                       Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Image Source="logotroc.png"
                               HeightRequest="120"
                               Aspect="AspectFit" />

                        <Label Text="{Binding MessageAccueil}"
                               FontSize="16"
                               TextColor="{StaticResource Ardoise}"
                               HorizontalTextAlignment="Center"
                               FontAttributes="Bold" />
                    </VerticalStackLayout>
                </Frame>

                <!-- Statistiques utilisateur -->
                <Frame BackgroundColor="White"
                       CornerRadius="15"
                       HasShadow="True"
                       Padding="20">
                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto">

                        <VerticalStackLayout Grid.Column="0"
                                             HorizontalOptions="Center"
                                             Spacing="5">
                            <Label Text="{Binding NombreMesAnnonces}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Terracotta}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Mes annonces"
                                   FontSize="14"
                                   TextColor="{StaticResource Ardoise}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1"
                                             HorizontalOptions="Center"
                                             Spacing="5">
                            <Label Text="{Binding NombreConversations}"
                                   FontSize="28"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource VertSauge}"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Conversations"
                                   FontSize="14"
                                   TextColor="{StaticResource Ardoise}"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Frame>

                <!-- Actions rapides -->
                <Frame BackgroundColor="White"
                       CornerRadius="15"
                       HasShadow="True"
                       Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="Actions rapides"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Ardoise}"
                               HorizontalTextAlignment="Center" />

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                            <Button Grid.Column="0"
                                    x:Name="DonnerButton"
                                    Text="🎁 Donner"
                                    Command="{Binding GoToCreationAnnonceCommand}"
                                    BackgroundColor="{StaticResource Terracotta}"
                                    TextColor="White"
                                    CornerRadius="25"
                                    HeightRequest="50"
                                    FontAttributes="Bold" />

                            <Button Grid.Column="1"
                                    x:Name="ExplorerButton"
                                    Text="🔍 Explorer"
                                    Command="{Binding GoToAnnoncesCommand}"
                                    BackgroundColor="{StaticResource VertSauge}"
                                    TextColor="White"
                                    CornerRadius="25"
                                    HeightRequest="50"
                                    FontAttributes="Bold" />
                        </Grid>
                    </VerticalStackLayout>
                </Frame>

                <!-- Section des offres récentes -->
                <Frame BackgroundColor="White"
                       CornerRadius="15"
                       HasShadow="True"
                       Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                            <Label Grid.Column="0"
                                   Text="Offres récentes"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Ardoise}"
                                   VerticalTextAlignment="Center" />

                            <Button Grid.Column="1"
                                    Text="Voir tout"
                                    Command="{Binding GoToAnnoncesCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource Terracotta}"
                                    FontSize="14"
                                    Padding="0" />
                        </Grid>

                        <!-- Liste des annonces récentes -->
                        <CollectionView ItemsSource="{Binding AnnoncesRecentes}"
                                        HeightRequest="300">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="10" />
                            </CollectionView.ItemsLayout>

                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Annonce">
                                    <Frame BackgroundColor="{StaticResource BeigeClair}"
                                           CornerRadius="10"
                                           Padding="15"
                                           HasShadow="False">
                                        <Frame.GestureRecognizers>
                                            <TapGestureRecognizer
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:DashboardViewModel}}, Path=VoirAnnonceCommand}"
                                                CommandParameter="{Binding .}" />
                                        </Frame.GestureRecognizers>

                                        <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="15">
                                            <!-- Image de l'annonce ou icône par défaut -->
                                            <Frame Grid.Column="0"
                                                   WidthRequest="60"
                                                   HeightRequest="60"
                                                   CornerRadius="8"
                                                   Padding="0"
                                                   HasShadow="False"
                                                   BackgroundColor="{StaticResource VertSauge}">
                                                <Label Text="{Binding Type, StringFormat='{0}'}"
                                                       FontSize="12"
                                                       TextColor="White"
                                                       HorizontalTextAlignment="Center"
                                                       VerticalTextAlignment="Center"
                                                       FontAttributes="Bold" />
                                            </Frame>

                                            <!-- Informations de l'annonce -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="5">
                                                <Label Text="{Binding Titre}"
                                                       FontSize="16"
                                                       FontAttributes="Bold"
                                                       TextColor="{StaticResource Ardoise}"
                                                       LineBreakMode="TailTruncation" />

                                                <Label Text="{Binding Description}"
                                                       FontSize="14"
                                                       TextColor="{StaticResource Ardoise}"
                                                       LineBreakMode="TailTruncation"
                                                       MaxLines="2" />

                                                <Label Text="{Binding Categorie}"
                                                       FontSize="12"
                                                       TextColor="{StaticResource Terracotta}"
                                                       FontAttributes="Italic" />
                                            </VerticalStackLayout>

                                            <!-- Badge du type d'annonce -->
                                            <Frame Grid.Column="2"
                                                   BackgroundColor="{StaticResource Terracotta}"
                                                   CornerRadius="15"
                                                   Padding="10,5"
                                                   HasShadow="False">
                                                <Label Text="{Binding Type}"
                                                       FontSize="12"
                                                       TextColor="White"
                                                       FontAttributes="Bold" />
                                            </Frame>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>

                            <!-- Message si aucune annonce -->
                            <CollectionView.EmptyView>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="10">
                                    <Label Text="🏷️"
                                           FontSize="50"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Aucune annonce récente"
                                           FontSize="16"
                                           TextColor="{StaticResource Ardoise}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Soyez le premier à publier !"
                                           FontSize="14"
                                           TextColor="{StaticResource Ardoise}"
                                           HorizontalTextAlignment="Center"
                                           FontAttributes="Italic" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Section Fonctionnalités Premium -->
                <Frame BackgroundColor="White"
                       CornerRadius="15"
                       HasShadow="True"
                       Padding="20">
                    <VerticalStackLayout Spacing="15">
                        <Label Text="🌟 Fonctionnalités Premium"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Terracotta}"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Regardez une courte publicité pour débloquer des avantages !"
                               FontSize="14"
                               TextColor="{StaticResource Ardoise}"
                               HorizontalTextAlignment="Center" />

                        <!-- Grille des fonctionnalités premium -->
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                            <!-- Bouton pour 2h sans pub -->
                            <Frame Grid.Column="0" Grid.Row="0"
                                   BackgroundColor="{StaticResource BeigeClair}"
                                   CornerRadius="12"
                                   Padding="15"
                                   HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding WatchAdForAdFreeCommand}" />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                    <Label Text="🚫"
                                           FontSize="24"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="2h sans pub"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Ardoise}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="📺 Regarder"
                                           FontSize="10"
                                           TextColor="{StaticResource Terracotta}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>

                            <!-- Bouton pour crédits boost -->
                            <Frame Grid.Column="1" Grid.Row="0"
                                   BackgroundColor="{StaticResource BeigeClair}"
                                   CornerRadius="12"
                                   Padding="15"
                                   HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding WatchAdForBoostCreditsCommand}" />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                    <Label Text="🚀"
                                           FontSize="24"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="Boost annonce"
                                           FontSize="12"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Ardoise}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="📺 Regarder"
                                           FontSize="10"
                                           TextColor="{StaticResource Terracotta}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>

                            <!-- Bouton pour statistiques -->
                            <Frame Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2"
                                   BackgroundColor="{StaticResource BeigeClair}"
                                   CornerRadius="12"
                                   Padding="15"
                                   HasShadow="False">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding WatchAdForStatsCommand}" />
                                </Frame.GestureRecognizers>
                                <StackLayout Orientation="Horizontal" Spacing="10" HorizontalOptions="Center">
                                    <Label Text="📊"
                                           FontSize="24"
                                           VerticalTextAlignment="Center" />
                                    <StackLayout Spacing="2">
                                        <Label Text="Statistiques avancées (24h)"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource Ardoise}" />
                                        <Label Text="📺 Regarder une publicité"
                                               FontSize="10"
                                               TextColor="{StaticResource Terracotta}" />
                                    </StackLayout>
                                </StackLayout>
                            </Frame>
                        </Grid>

                        <!-- Statut premium actuel -->
                        <Border BackgroundColor="{StaticResource VertSauge}"
                                Stroke="{StaticResource VertSauge}"
                                StrokeThickness="1"
                                Padding="10,5"
                                IsVisible="{Binding IsAdFreeActive}">
                            <Label
                                Text="{Binding AdFreeUntil, StringFormat=&quot;✨ Mode sans pub actif jusqu&apos;à {0:HH:mm}&quot;}"
                                TextColor="White"
                                FontSize="12"
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Center" />
                        </Border>

                        <Border BackgroundColor="{StaticResource Terracotta}"
                                Stroke="{StaticResource Terracotta}"
                                StrokeThickness="1"
                                Padding="10,5"
                                IsVisible="{Binding BoostCredits, Converter={StaticResource IntToBoolConverter}}">
                            <Label Text="{Binding BoostCredits, StringFormat='🚀 {0} crédits de boost disponibles'}"
                                   TextColor="White"
                                   FontSize="12"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                        </Border>
                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
    
    <!-- Overlay pour les conseils -->
    <views:TipOverlayView x:Name="TipOverlay" />
    </Grid>
</ContentPage>