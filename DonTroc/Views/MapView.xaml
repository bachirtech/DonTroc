<?xml version="1.0" encoding="utf-8" ?>
<!-- Fichier: DonTroc/Views/MapView.xaml -->
<!-- Page Carte redesignée — Design DonTroc cohérent -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             x:DataType="viewModels:MapViewModel"
             x:Class="DonTroc.Views.MapView"
             Title="Carte"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light={StaticResource BeigeClair}, Dark={StaticResource BeigeSombre}}">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- ═══════════════════════════════════════════════ -->
        <!-- HEADER GRADIENT avec recherche                  -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 0,0,20,20"
                Padding="16,12,16,14"
                ZIndex="10">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#8B5A3A}" Offset="0.0" />
                    <GradientStop Color="{AppThemeBinding Light=#C47A58, Dark=#6B4A32}" Offset="0.5" />
                    <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#5A7A3E}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Border.Shadow>
                <Shadow Brush="#40000000" Offset="0,4" Radius="12" Opacity="0.3" />
            </Border.Shadow>

            <VerticalStackLayout Spacing="10">

                <!-- Ligne titre + bouton retour -->
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <!-- Bouton retour -->
                    <Border Grid.Column="0"
                            StrokeShape="RoundRectangle 14,14,14,14"
                            StrokeThickness="0"
                            BackgroundColor="#25FFFFFF"
                            WidthRequest="38" HeightRequest="38"
                            Padding="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding BackCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="←"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="White"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>

                    <!-- Titre -->
                    <Label Grid.Column="1"
                           Text="🗺️ Carte"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="White"
                           VerticalTextAlignment="Center" />

                    <!-- Bouton filtre -->
                    <Border Grid.Column="2"
                            StrokeShape="RoundRectangle 14,14,14,14"
                            StrokeThickness="0"
                            BackgroundColor="#25FFFFFF"
                            WidthRequest="38" HeightRequest="38"
                            Padding="0">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding FilterCommand}" />
                        </Border.GestureRecognizers>
                        <Label Text="🎛️"
                               FontSize="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                </Grid>

                <!-- Barre de recherche -->
                <Border StrokeShape="RoundRectangle 16,16,16,16"
                        StrokeThickness="0"
                        BackgroundColor="#30FFFFFF"
                        Padding="4,0"
                        HeightRequest="44">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="6" Padding="12,0">
                        <!-- Champ de recherche -->
                        <Entry Grid.Column="0"
                               x:Name="SearchEntry"
                               Placeholder="Rechercher une adresse..."
                               Text="{Binding SearchAddress}"
                               BackgroundColor="Transparent"
                               PlaceholderColor="#C0FFFFFF"
                               TextColor="White"
                               FontSize="14"
                               VerticalOptions="Center" />

                        <!-- Bouton recherche -->
                        <Border Grid.Column="1"
                                StrokeShape="RoundRectangle 12,12,12,12"
                                StrokeThickness="0"
                                BackgroundColor="#20FFFFFF"
                                WidthRequest="34" HeightRequest="34"
                                Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SearchCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="🔍"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Bouton localisation -->
                        <Border Grid.Column="2"
                                StrokeShape="RoundRectangle 12,12,12,12"
                                StrokeThickness="0"
                                Padding="0"
                                WidthRequest="34" HeightRequest="34">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                                    <GradientStop Color="{AppThemeBinding Light=#E5A07E, Dark=#C47A58}" Offset="1.0" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.Shadow>
                                <Shadow Brush="#30D98C6A" Offset="0,2" Radius="4" Opacity="0.4" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding LocationCommand}" />
                            </Border.GestureRecognizers>
                            <Label Text="📍"
                                   FontSize="16"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- GOOGLE MAPS                                     -->
        <!-- ═══════════════════════════════════════════════ -->
        <maps:Map Grid.Row="1"
                  x:Name="GoogleMap"
                  IsShowingUser="True"
                  MapType="Street"
                  VerticalOptions="Fill"
                  HorizontalOptions="Fill" />

        <!-- ═══════════════════════════════════════════════ -->
        <!-- PANNEAU D'INFORMATIONS EN BAS                   -->
        <!-- ═══════════════════════════════════════════════ -->
        <Border Grid.Row="2"
                StrokeShape="RoundRectangle 20,20,0,0"
                StrokeThickness="0"
                BackgroundColor="{AppThemeBinding Light={StaticResource DonTrocCardBackground}, Dark={StaticResource DonTrocCardBackgroundDark}}"
                Padding="18,14,18,16"
                Margin="0"
                IsVisible="{Binding HasUserLocation}">
            <Border.Shadow>
                <Shadow Brush="#30000000" Offset="0,-4" Radius="12" Opacity="0.25" />
            </Border.Shadow>

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                <!-- Infos position -->
                <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Center">
                    <Label Text="{Binding CurrentLocationText}"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                           LineBreakMode="TailTruncation" />
                    <Label Text="{Binding NearbyAnnouncements.Count, StringFormat='{0} annonces à proximité'}"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light={StaticResource Ardoise}, Dark={StaticResource ArdoiseSombre}}"
                           Opacity="0.6" />
                </VerticalStackLayout>

                <!-- Bouton actualiser gradient -->
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 16,16,16,16"
                        StrokeThickness="0"
                        WidthRequest="44" HeightRequest="44"
                        Padding="0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="{AppThemeBinding Light=#D98C6A, Dark=#B8704E}" Offset="0.0" />
                            <GradientStop Color="{AppThemeBinding Light=#C47A58, Dark=#A86840}" Offset="0.5" />
                            <GradientStop Color="{AppThemeBinding Light=#A8C686, Dark=#8DAE6A}" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Shadow>
                        <Shadow Brush="{AppThemeBinding Light=#40D98C6A, Dark=#30000000}" Offset="0,3" Radius="8" Opacity="0.4" />
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding RefreshCommand}" />
                    </Border.GestureRecognizers>
                    <Label Text="🔄"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- INDICATEUR DE CHARGEMENT                        -->
        <!-- ═══════════════════════════════════════════════ -->
        <ActivityIndicator Grid.Row="1"
                           IsVisible="{Binding IsBusy}"
                           IsRunning="{Binding IsBusy}"
                           Color="{AppThemeBinding Light={StaticResource Terracotta}, Dark={StaticResource TerracottaSombre}}"
                           WidthRequest="48"
                           HeightRequest="48"
                           VerticalOptions="Center"
                           HorizontalOptions="Center" />
    </Grid>
</ContentPage>
