<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:viewModels="clr-namespace:DonTroc.ViewModels"
             x:DataType="viewModels:MapViewModel"
             x:Class="DonTroc.Views.MapView"
             Title="Carte"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F5F5">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Barre de recherche et filtres avec bouton retour -->
        <Frame Grid.Row="0" BackgroundColor="White" Margin="10,5" CornerRadius="25" HasShadow="True">
            <Grid Margin="15,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Bouton retour -->
                <Button Grid.Column="0"
                        x:Name="BackButton"
                        Text="←"
                        FontSize="20"
                        FontAttributes="Bold"
                        Padding="5,0"
                        BackgroundColor="Transparent"
                        TextColor="#007ACC"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Command="{Binding BackCommand}"
                        VerticalOptions="Center" />

                <Entry Grid.Column="1" 
                       x:Name="SearchEntry"
                       Placeholder="Rechercher une adresse..."
                       Text="{Binding SearchAddress}"
                       BackgroundColor="Transparent"
                       PlaceholderColor="Gray"
                       TextColor="Black"
                       VerticalOptions="Center" />

                <Button Grid.Column="2"
                        x:Name="SearchButton"
                        Text="🔍"
                        FontSize="18"
                        Padding="2"
                        BackgroundColor="Transparent"
                        TextColor="#007ACC"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Command="{Binding SearchCommand}" />

                <Button Grid.Column="3"
                        x:Name="LocationButton"
                        Text="📍"
                        FontSize="18"
                        Padding="2"
                        BackgroundColor="#D98C6A"
                        TextColor="White"
                        WidthRequest="30"
                        HeightRequest="30"
                        CornerRadius="20"
                        Command="{Binding LocationCommand}" />

                <Button Grid.Column="4"
                        x:Name="FilterButton"
                        Text="🎛️"
                        FontSize="18"
                        Padding="2"
                        BackgroundColor="Transparent"
                        TextColor="#007ACC"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Command="{Binding FilterCommand}" />
            </Grid>
        </Frame>

        <!-- Google Maps -->
        <maps:Map Grid.Row="1" 
                  x:Name="GoogleMap"
                  Margin="10,0,10,10"
                  IsShowingUser="True"
                  MapType="Street"
                  VerticalOptions="FillAndExpand"
                  HorizontalOptions="FillAndExpand" />

        <!-- Panneau d'informations en bas -->
        <Frame Grid.Row="2" 
               BackgroundColor="White" 
               Margin="10,0,10,10" 
               CornerRadius="15" 
               HasShadow="True"
               IsVisible="{Binding HasUserLocation}">
            <Grid Margin="15,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Label Grid.Row="0" Grid.Column="0"
                       Text="{Binding CurrentLocationText}"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="#333333"
                       VerticalOptions="Center" />

                <Label Grid.Row="1" Grid.Column="0"
                       Text="{Binding NearbyAnnouncements.Count, StringFormat='{0} annonces à proximité'}"
                       FontSize="12"
                       TextColor="#666666"
                       VerticalOptions="Center" />

                <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="1"
                        Text="🔄"
                        FontSize="18"
                        Padding="2"
                        BackgroundColor="#D98C6A"
                        TextColor="White"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        Command="{Binding RefreshCommand}" />
            </Grid>
        </Frame>

        <!-- Indicateur de chargement -->
        <ActivityIndicator Grid.Row="1"
                          IsVisible="{Binding IsBusy}"
                          IsRunning="{Binding IsBusy}"
                          Color="#007ACC"
                          VerticalOptions="Center"
                          HorizontalOptions="Center" />
    </Grid>
</ContentPage>
